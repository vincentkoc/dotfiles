{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/bin/agent-attn-set reset codex",
            "timeout": 2
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/bin/agent-attn-set reset codex",
            "timeout": 2
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/bin/agent-attn-set waiting codex",
            "timeout": 2
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/vincentkoc/.codex/plugins/cache/vincentkoc-local/tokenjuice/local/scripts/post_tool_use_tokenjuice.py",
            "statusMessage": "compacting bash output with tokenjuice"
          }
        ]
      }
    ]
  }
}
