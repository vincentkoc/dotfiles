#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: quickssh [-m] [-s] [-t] [-l local_port] [-d destination_port] <host>

Options:
  -m  use mosh
  -s  run screen -xRR after connecting
  -t  attach or create tmux after connecting
  -l  local port for SSH forwarding
  -d  remote destination port for SSH forwarding

Plain SSH config hosts are supported directly; legacy .extra aliases remain available.
EOF
}

extras_path() {
  printf '%s\n' "${EXTRASPATH:-$HOME/Library/Mobile Documents/com~apple~CloudDocs/dotfiles/.extra}"
}

load_legacy_hosts() {
  local hosts_file

  hosts_file="$(extras_path)/quickssh_hosts.sh"
  [[ -f "$hosts_file" ]] || return 1
  # shellcheck source=/dev/null
  source "$hosts_file"
}

copy_password() {
  local password="$1"

  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s' "$password" | pbcopy
    return 0
  fi
  if command -v xclip >/dev/null 2>&1; then
    printf '%s' "$password" | xclip -selection clipboard
    return 0
  fi
  if command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$password" | wl-copy
    return 0
  fi

  return 1
}

password_from_onepassword() {
  local alias="$1"
  local account_arg=()

  [[ -n "${QUICKSSH_OP_ACCOUNT:-}" ]] && account_arg=(--account "$QUICKSSH_OP_ACCOUNT")
  op item get "ssh_$alias" "${account_arg[@]}" --fields password | tr -d '\n'
}

resolve_legacy_host() {
  local alias="$1"
  local host_info_var host_info user host port password

  load_legacy_hosts || return 1
  host_info_var="quickssh_hosts_${alias}"
  host_info="${!host_info_var:-}"
  [[ -n "$host_info" ]] || return 1

  IFS=: read -r user host port password _ <<< "$host_info"
  [[ -n "$host" ]] || return 1
  port="${port:-22}"

  if [[ "$password" == "\$1password" ]]; then
    password="$(password_from_onepassword "$alias")"
  fi

  if [[ -n "${password:-}" ]]; then
    if copy_password "$password"; then
      printf 'quickssh: copied password for legacy alias %s; clipboard is not tracked by ssh\n' "$alias" >&2
    else
      printf 'quickssh: legacy alias %s has a password, but no clipboard command is available\n' "$alias" >&2
    fi
  fi

  if [[ -n "$user" ]]; then
    printf '%s\t%s\t%s\n' "$user@$host" "$port" "$alias"
  else
    printf '%s\t%s\t%s\n' "$host" "$port" "$alias"
  fi
}

list_hosts() {
  local hosts_file key

  printf 'SSH config hosts are supported directly, e.g. quickssh m1\n'

  hosts_file="$(extras_path)/quickssh_hosts.sh"
  [[ -f "$hosts_file" ]] || return 0

  if load_legacy_hosts && declare -p quickssh_hosts >/dev/null 2>&1; then
    printf '\nLegacy quickssh aliases:\n'
    for key in "${quickssh_hosts[@]}"; do
      printf '  %s\n' "$key"
    done
  fi
}

use_mosh=false
use_screen=false
use_tmux=false
local_port=""
destination_port=""

while getopts ":mstl:d:h" option; do
  case "$option" in
    m) use_mosh=true ;;
    s) use_screen=true ;;
    t) use_tmux=true ;;
    l) local_port="$OPTARG" ;;
    d) destination_port="$OPTARG" ;;
    h)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done
shift $((OPTIND - 1))

if [[ $# -ne 1 ]]; then
  usage >&2
  printf '\n' >&2
  list_hosts >&2
  exit 2
fi

input="$1"
target="$input"
port=""

if resolved="$(resolve_legacy_host "$input")"; then
  IFS=$'\t' read -r target port _ <<< "$resolved"
fi

remote_command=()
has_remote_command=false
if [[ "$use_tmux" == "true" ]]; then
  remote_command=(sh -lc 'tmux attach || tmux new-session')
  has_remote_command=true
elif [[ "$use_screen" == "true" ]]; then
  remote_command=(screen -xRR)
  has_remote_command=true
fi

ssh_args=(-o ServerAliveInterval=15 -o ServerAliveCountMax=3)
[[ -n "$port" ]] && ssh_args+=(-p "$port")

if [[ -n "$local_port" || -n "$destination_port" ]]; then
  if [[ -z "$local_port" || -z "$destination_port" ]]; then
    printf 'quickssh: both -l and -d are required for forwarding\n' >&2
    exit 2
  fi
  if [[ "$use_mosh" == "true" ]]; then
    printf 'quickssh: port forwarding is not supported with mosh\n' >&2
    exit 2
  fi
  ssh_args+=(-L "$local_port:localhost:$destination_port")
fi

if [[ "$use_mosh" == "true" ]]; then
  mosh_ssh=(ssh "${ssh_args[@]}")
  if [[ "$has_remote_command" == "true" ]]; then
    exec mosh -4 -a --bind-server=any --ssh="${mosh_ssh[*]}" -- "$target" "${remote_command[@]}"
  fi
  exec mosh -4 -a --bind-server=any --ssh="${mosh_ssh[*]}" -- "$target"
fi

if [[ "$has_remote_command" == "true" ]]; then
  exec ssh "${ssh_args[@]}" "$target" "${remote_command[@]}"
fi
exec ssh "${ssh_args[@]}" "$target"
