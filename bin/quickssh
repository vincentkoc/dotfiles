#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: quickssh [-m] [-s] [-t] [-l local_port] [-d destination_port] [host]

Options:
  -m  use mosh
  -s  run screen -xRR after connecting
  -t  attach or create tmux after connecting
  -l  local port for SSH forwarding
  -d  remote destination port for SSH forwarding

Run without a host to choose one interactively.
Plain SSH config hosts are supported directly; legacy .extra aliases remain available.
EOF
}

extras_path() {
  printf '%s\n' "${EXTRASPATH:-$HOME/Library/Mobile Documents/com~apple~CloudDocs/dotfiles/.extra}"
}

load_legacy_hosts() {
  local hosts_file

  hosts_file="$(extras_path)/quickssh_hosts.sh"
  [[ -f "$hosts_file" ]] || return 1
  # shellcheck source=/dev/null
  source "$hosts_file"
}

copy_password() {
  local password="$1"

  if command -v pbcopy >/dev/null 2>&1; then
    printf '%s' "$password" | pbcopy
    return 0
  fi
  if command -v xclip >/dev/null 2>&1; then
    printf '%s' "$password" | xclip -selection clipboard
    return 0
  fi
  if command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$password" | wl-copy
    return 0
  fi

  return 1
}

password_from_onepassword() {
  local alias="$1"
  local account_arg=()

  [[ -n "${QUICKSSH_OP_ACCOUNT:-}" ]] && account_arg=(--account "$QUICKSSH_OP_ACCOUNT")
  op item get "ssh_$alias" "${account_arg[@]}" --fields password | tr -d '\n'
}

resolve_legacy_host() {
  local alias="$1"
  local host_info_var host_info user host port password

  load_legacy_hosts || return 1
  host_info_var="quickssh_hosts_${alias}"
  host_info="${!host_info_var:-}"
  [[ -n "$host_info" ]] || return 1

  IFS=: read -r user host port password _ <<< "$host_info"
  [[ -n "$host" ]] || return 1
  port="${port:-22}"

  if [[ "$password" == "\$1password" ]]; then
    password="$(password_from_onepassword "$alias")"
  fi

  if [[ -n "${password:-}" ]]; then
    if copy_password "$password"; then
      printf 'quickssh: copied password for legacy alias %s; clipboard is not tracked by ssh\n' "$alias" >&2
    else
      printf 'quickssh: legacy alias %s has a password, but no clipboard command is available\n' "$alias" >&2
    fi
  fi

  if [[ -n "$user" ]]; then
    printf '%s\t%s\t%s\n' "$user@$host" "$port" "$alias"
  else
    printf '%s\t%s\t%s\n' "$host" "$port" "$alias"
  fi
}

list_hosts() {
  local hosts_file key

  printf 'SSH config hosts are supported directly, e.g. quickssh m1\n'

  hosts_file="$(extras_path)/quickssh_hosts.sh"
  [[ -f "$hosts_file" ]] || return 0

  # shellcheck disable=SC2154 # Sourced from the private legacy hosts file.
  if load_legacy_hosts && declare -p quickssh_hosts >/dev/null 2>&1; then
    printf '\nLegacy quickssh aliases:\n'
    for key in "${quickssh_hosts[@]}"; do
      printf '  %s\n' "$key"
    done
  fi
}

list_legacy_aliases() {
  local key

  # shellcheck disable=SC2154 # Sourced from the private legacy hosts file.
  if load_legacy_hosts && declare -p quickssh_hosts >/dev/null 2>&1; then
    for key in "${quickssh_hosts[@]}"; do
      printf '%s\n' "$key"
    done
  fi
}

legacy_host_prefers_mosh() {
  local alias="$1" key

  # shellcheck disable=SC2154 # Sourced from the private legacy hosts file.
  if load_legacy_hosts && declare -p quickssh_mosh_hosts >/dev/null 2>&1; then
    for key in "${quickssh_mosh_hosts[@]}"; do
      [[ "$key" == "$alias" ]] && return 0
    done
  fi

  return 1
}

set_tmux_connection_title() {
  local title="$1" window_id pane_count

  [[ -n "${TMUX_PANE:-}" ]] || return 0
  command -v tmux >/dev/null 2>&1 || return 0

  tmux set-option -pt "$TMUX_PANE" @tt_base_title "$title" 2>/dev/null || true
  tmux select-pane -t "$TMUX_PANE" -T "$title" 2>/dev/null || true

  window_id="$(tmux display-message -p -t "$TMUX_PANE" '#{window_id}' 2>/dev/null || true)"
  [[ -n "$window_id" ]] || return 0
  pane_count="$(tmux display-message -p -t "$window_id" '#{window_panes}' 2>/dev/null || true)"
  [[ "$pane_count" == "1" ]] || return 0

  tmux set-window-option -t "$window_id" automatic-rename off 2>/dev/null || true
  tmux rename-window -t "$window_id" "$title" 2>/dev/null || true
}

ssh_config_files() {
  local file file_dir line key pattern expanded i
  local -a files=("$HOME/.ssh/config")

  for ((i = 0; i < ${#files[@]}; i++)); do
    file="${files[$i]}"
    [[ -f "$file" ]] || continue
    printf '%s\n' "$file"
    file_dir="$(dirname "$file")"

    while IFS= read -r line; do
      line="${line%%#*}"
      # shellcheck disable=SC2086 # Split OpenSSH Include arguments like ssh_config does.
      set -- $line
      [[ $# -gt 1 ]] || continue

      key="$1"
      case "$key" in
        [Ii][Nn][Cc][Ll][Uu][Dd][Ee]) ;;
        *) continue ;;
      esac
      shift

      for pattern in "$@"; do
        pattern="${pattern/#\~/$HOME}"
        [[ "$pattern" = /* ]] || pattern="$file_dir/$pattern"
        for expanded in $pattern; do
          [[ -f "$expanded" ]] && files+=("$expanded")
        done
      done
    done < "$file"
  done
}

list_ssh_config_hosts() {
  local file

  while IFS= read -r file; do
    awk '
      /^[[:space:]]*(#|$)/ { next }
      tolower($1) == "host" {
        for (i = 2; i <= NF; i++) {
          if ($i !~ /[*?!%]/) {
            print $i
          }
        }
      }
    ' "$file"
  done < <(ssh_config_files) | sort -fu
}

choose_with_fzf() {
  command -v fzf >/dev/null 2>&1 || return 1
  printf '%s\n' "$@" | fzf --prompt='quickssh > ' --height=40% --layout=reverse --border
}

choose_with_select() {
  local options=("$@")
  local choice
  PS3="quickssh> "

  select choice in "${options[@]}"; do
    [[ -n "${choice:-}" ]] || continue
    printf '%s\n' "$choice"
    return 0
  done
}

choose_option() {
  local options=("$@")
  local selected

  if selected="$(choose_with_fzf "${options[@]}")"; then
    printf '%s\n' "$selected"
    return 0
  fi

  choose_with_select "${options[@]}"
}

choose_host() {
  local host row selection
  local -a options=()

  while IFS= read -r host; do
    [[ -n "$host" ]] || continue
    options+=("$(printf '%-28s %s' "$host" "quickssh alias")")
  done < <(list_legacy_aliases | awk 'NF && !seen[$0]++')

  while IFS= read -r host; do
    [[ -n "$host" ]] || continue
    options+=("$(printf '%-28s %s' "$host" "ssh config host")")
  done < <(list_ssh_config_hosts)

  if [[ ${#options[@]} -eq 0 ]]; then
    usage >&2
    printf '\nquickssh: no hosts found to choose from\n' >&2
    exit 2
  fi

  selection="$(choose_option "${options[@]}")"
  row="${selection%%[[:space:]]*}"
  [[ -n "$row" ]] || return 130
  printf '%s\n' "$row"
}

use_mosh=false
mosh_requested=false
use_screen=false
use_tmux=false
local_port=""
destination_port=""

while getopts ":mstl:d:h" option; do
  case "$option" in
    m)
      use_mosh=true
      mosh_requested=true
      ;;
    s) use_screen=true ;;
    t) use_tmux=true ;;
    l) local_port="$OPTARG" ;;
    d) destination_port="$OPTARG" ;;
    h)
      usage
      exit 0
      ;;
    *)
      usage >&2
      exit 2
      ;;
  esac
done
shift $((OPTIND - 1))

if [[ $# -eq 0 ]]; then
  input="$(choose_host)"
elif [[ $# -eq 1 ]]; then
  input="$1"
else
  usage >&2
  printf '\n' >&2
  list_hosts >&2
  exit 2
fi

target="$input"
port=""

if resolved="$(resolve_legacy_host "$input")"; then
  IFS=$'\t' read -r target port _ <<< "$resolved"
  if legacy_host_prefers_mosh "$input"; then
    use_mosh=true
  fi
fi

remote_command=()
has_remote_command=false
if [[ "$use_tmux" == "true" ]]; then
  remote_command=(sh -lc 'tmux attach || tmux new-session')
  has_remote_command=true
elif [[ "$use_screen" == "true" ]]; then
  remote_command=(screen -xRR)
  has_remote_command=true
fi

ssh_args=(-o ServerAliveInterval=15 -o ServerAliveCountMax=3)
[[ -n "$port" ]] && ssh_args+=(-p "$port")

if [[ -n "$local_port" || -n "$destination_port" ]]; then
  if [[ -z "$local_port" || -z "$destination_port" ]]; then
    printf 'quickssh: both -l and -d are required for forwarding\n' >&2
    exit 2
  fi
  if [[ "$use_mosh" == "true" ]]; then
    if [[ "$mosh_requested" == "true" ]]; then
      printf 'quickssh: port forwarding is not supported with mosh\n' >&2
      exit 2
    fi
    use_mosh=false
  fi
  ssh_args+=(-L "$local_port:localhost:$destination_port")
fi

if [[ "$use_mosh" == "true" ]]; then
  set_tmux_connection_title "$input"
  mosh_ssh=(ssh "${ssh_args[@]}")
  if [[ "$has_remote_command" == "true" ]]; then
    exec mosh -4 -a --bind-server=any --ssh="${mosh_ssh[*]}" -- "$target" "${remote_command[@]}"
  fi
  exec mosh -4 -a --bind-server=any --ssh="${mosh_ssh[*]}" -- "$target"
fi

if [[ "$has_remote_command" == "true" ]]; then
  exec ssh "${ssh_args[@]}" "$target" "${remote_command[@]}"
fi
exec ssh "${ssh_args[@]}" "$target"
