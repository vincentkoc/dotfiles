#!/usr/bin/env bash
set -euo pipefail

TMUX_BIN="/opt/homebrew/bin/tmux"
if [[ ! -x "$TMUX_BIN" ]]; then
  TMUX_BIN="/usr/local/bin/tmux"
fi
if [[ ! -x "$TMUX_BIN" ]]; then
  TMUX_BIN="/usr/bin/tmux"
fi
if [[ ! -x "$TMUX_BIN" ]]; then
  echo "tmux not found at common paths" >&2
  exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
DOTFILES_DIR="$(cd "$SCRIPT_DIR/.." && pwd -P)"

attach_or_switch() {
  local session="$1"

  if [[ -n "${TMUX:-}" ]]; then
    exec "$TMUX_BIN" switch-client -t "$session"
  fi

  exec "$TMUX_BIN" attach -t "$session"
}

mobile_group_session_name() {
  local source_session="$1"
  local sanitized
  sanitized="${source_session//[^A-Za-z0-9._-]/-}"
  printf 'ttm-%s\n' "$sanitized"
}

set_profile_metadata() {
  local session="$1"
  local profile="$2"
  "$TMUX_BIN" set-option -t "$session" -q @tt_profile "$profile"
}

send_literal_command() {
  local target="$1"
  local command="$2"

  "$TMUX_BIN" send-keys -t "$target" -l "$command"
  "$TMUX_BIN" send-keys -t "$target" Enter
}

shell_quote() {
  printf '%q' "$1"
}

default_login_shell() {
  local shell_path=""

  if command -v dscl >/dev/null 2>&1 && [[ -n "${USER:-}" ]]; then
    shell_path="$(dscl . -read "/Users/$USER" UserShell 2>/dev/null | awk '{print $2; exit}')"
  fi

  if [[ -z "$shell_path" && -n "${SHELL:-}" ]]; then
    shell_path="$SHELL"
  fi

  if [[ -z "$shell_path" || ! -x "$shell_path" ]]; then
    shell_path="/bin/zsh"
  fi

  printf '%s\n' "$shell_path"
}

default_login_shell_command() {
  local shell_path

  shell_path="$(default_login_shell)"
  printf '%s -il\n' "$(shell_quote "$shell_path")"
}

ensure_tmux_default_shell() {
  local shell_path

  shell_path="$(default_login_shell)"
  "$TMUX_BIN" set-option -gq default-shell "$shell_path" 2>/dev/null || true
  "$TMUX_BIN" set-option -gq -u default-command 2>/dev/null || true
}

agent_color_prefix() {
  printf 'env -u NO_COLOR -u TERMINFO CLICOLOR=1 CLICOLOR_FORCE=1 FORCE_COLOR=3 COLORTERM=truecolor TERMINFO_DIRS=$HOME/.terminfo:/usr/share/terminfo'
}

agent_kind_for_command() {
  local command="$1"

  case "$command" in
    *claude*)
      printf 'CLAUDE'
      ;;
    *codex*)
      printf 'CODEX'
      ;;
    *)
      printf 'SHELL'
      ;;
  esac
}

agent_label_format() {
  printf '#{?#{==:#{@tt_agent_kind},CLAUDE},CC,#{?#{==:#{@tt_agent_kind},CODEX},CX,TM}}'
}

agent_ready_format() {
  printf '#{?#{&&:#{||:#{==:#{@tt_agent_kind},CODEX},#{==:#{@tt_agent_kind},CLAUDE}},#{?#{m/r:^[⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏⠂],#{pane_title}},0,1}},1,0}'
}

set_agent_window_status_formats() {
  "$TMUX_BIN" set -g window-status-format "#[fg=#1a1b26,bg=#1a1b26,none]#[fg=#565f89,bg=#1a1b26,none] #I #W #[fg=#1a1b26,bg=#1a1b26,none]"
  "$TMUX_BIN" set -g window-status-current-format "#[fg=#1a1b26,bg=#7aa2f7,none]#[fg=#1a1b26,bg=#7aa2f7,bold] #I #W #[fg=#7aa2f7,bg=#1a1b26,none]"
  "$TMUX_BIN" set -g window-status-style "fg=#565f89,bg=#1a1b26,none"
  "$TMUX_BIN" set -g window-status-current-style "fg=#1a1b26,bg=#7aa2f7,bold"
}

git_pane_label() {
  local dir="$1"
  local branch

  [[ -d "$dir" ]] || return 0
  git -C "$dir" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0

  branch="$(git -C "$dir" branch --show-current 2>/dev/null || true)"
  if [[ -z "$branch" ]]; then
    branch="$(git -C "$dir" rev-parse --short HEAD 2>/dev/null || true)"
  fi
  [[ -n "$branch" ]] || return 0

  printf ' %s\n' "$branch"
}

set_pane_git_label() {
  local target="$1"
  local dir="$2"
  local git_label

  git_label="$(git_pane_label "$dir")"
  if [[ -n "$git_label" ]]; then
    "$TMUX_BIN" set-option -pt "$target" @tt_git_label "$git_label" 2>/dev/null || true
  else
    "$TMUX_BIN" set-option -pt "$target" -u @tt_git_label 2>/dev/null || true
  fi
}

clean_agent_command() {
  local command="$1"
  local prefix

  command="${command#\"}"
  command="${command%\"}"
  prefix="$(agent_color_prefix) "
  if [[ "$command" == "$prefix"* ]]; then
    command="${command#"$prefix"}"
  fi
  if [[ "$command" == env\ -u\ NO_COLOR\ CLICOLOR=1\ CLICOLOR_FORCE=1\ FORCE_COLOR=* ]]; then
    command="${command#env -u NO_COLOR CLICOLOR=1 CLICOLOR_FORCE=1 FORCE_COLOR=}"
    command="${command#* COLORTERM=truecolor }"
  fi
  if [[ "$command" == "zsh" || "$command" == "-" ]]; then
    command=""
  fi

  printf '%s\n' "$command"
}

apply_recovery_theme() {
  local ready
  ready="$(agent_ready_format)"

  ensure_tmux_rgb_terminfo

  "$TMUX_BIN" set -g base-index 1
  "$TMUX_BIN" set -g pane-base-index 1
  "$TMUX_BIN" set -g default-terminal "tmux-256color"
  "$TMUX_BIN" set -g terminal-features "xterm*:clipboard:ccolour:cstyle:extkeys:focus:title,screen*:title,rxvt*:ignorefkeys,xterm-256color:RGB:hyperlinks,tmux-256color:RGB:hyperlinks"
  "$TMUX_BIN" set -ga terminal-overrides ",*:Tc"
  "$TMUX_BIN" set -g allow-passthrough on
  "$TMUX_BIN" set -g set-clipboard on
  "$TMUX_BIN" set -g extended-keys on
  "$TMUX_BIN" set -g extended-keys-format csi-u
  "$TMUX_BIN" set-environment -gu NO_COLOR 2>/dev/null || true
  "$TMUX_BIN" set-environment -g CLICOLOR 1
  "$TMUX_BIN" set-environment -g CLICOLOR_FORCE 1
  "$TMUX_BIN" set-environment -gu FORCE_COLOR 2>/dev/null || true
  "$TMUX_BIN" set-environment -g COLORTERM truecolor
  "$TMUX_BIN" set-environment -gu TERMINFO 2>/dev/null || true
  "$TMUX_BIN" set-environment -g TERMINFO_DIRS "$HOME/.terminfo:/usr/share/terminfo"
  "$TMUX_BIN" set-environment -g TERM_PROGRAM "${TERM_PROGRAM:-ghostty}"
  "$TMUX_BIN" set-environment -g ITERM2_DISABLE_SHELL_INTEGRATION 1
  "$TMUX_BIN" set-environment -g ITERM_DISABLE_PROMPT_MARK 1
  "$TMUX_BIN" set -g mouse on
  "$TMUX_BIN" set -g history-limit 50000
  "$TMUX_BIN" set -g status on
  "$TMUX_BIN" set -g status-style "fg=#565f89,bg=#1a1b26,none"
  "$TMUX_BIN" set -g window-style "fg=default,bg=#1a1b26"
  "$TMUX_BIN" set -g window-active-style "fg=default,bg=#1a1b26"
  "$TMUX_BIN" set -g window-status-style "fg=#565f89,bg=#1a1b26,none"
  "$TMUX_BIN" set -g window-status-current-style "fg=#1a1b26,bg=#7aa2f7,bold"
  "$TMUX_BIN" set -g message-style "fg=#1a1b26,bg=#7aa2f7,bold"
  "$TMUX_BIN" set -g mode-style "fg=#1a1b26,bg=#7aa2f7,bold"
  "$TMUX_BIN" set -g pane-border-style "fg=#{?$ready,#ff9e64,#292e42},bg=default"
  "$TMUX_BIN" set -g pane-active-border-style "fg=#{?$ready,#ff9e64,#7aa2f7},bg=default"
  "$TMUX_BIN" set -g status-left "#[fg=#15161e,bg=#ff9e64,bold] ❐ #S #[fg=#ff9e64,bg=#1a1b26,none] "
  "$TMUX_BIN" set -g status-right "#[fg=#565f89,bg=#1a1b26]#{?client_prefix,⌨ ,  }#{?mouse,↗ ,  }#{?session_many_attached,⚇ ,}#{?pane_synchronized,⚏ ,}#[fg=#9ece6a,bg=#1a1b26,none]#[fg=#1a1b26,bg=#9ece6a,bold] CX SAVE #[fg=#f7768e,bg=#9ece6a,none]#[fg=#c0caf5,bg=#f7768e,bold] %R %d %b vincentkoc@#h "
  set_agent_window_status_formats
  "$TMUX_BIN" set -g pane-border-status off
  "$TMUX_BIN" set -g prefix C-b
  "$TMUX_BIN" set -g prefix2 C-a
  "$TMUX_BIN" bind-key C-a send-prefix -2
  "$TMUX_BIN" bind-key s choose-tree -Zs
  "$TMUX_BIN" bind-key R send-keys -l "printf '\\033[?1000l\\033[?1002l\\033[?1003l\\033[?1006l\\033[?1015l\\033[?2004l'; stty sane; reset" \; send-keys Enter
  "$TMUX_BIN" refresh-client -S 2>/dev/null || true
}

ensure_tmux_rgb_terminfo() {
  local tmp

  if TERMINFO="$HOME/.terminfo" infocmp -x tmux-256color 2>/dev/null | grep -q 'setrgbf='; then
    return 0
  fi
  command -v infocmp >/dev/null 2>&1 || return 0
  command -v tic >/dev/null 2>&1 || return 0

  mkdir -p "$HOME/.terminfo"
  tmp="$(mktemp "${TMPDIR:-/tmp}/tmux-256color-rgb.XXXXXX")"
  if ! TERMINFO= infocmp -x tmux-256color >"$tmp" 2>/dev/null; then
    rm -f "$tmp"
    return 0
  fi

  {
    printf '\tRGB,\n'
    printf '\tTc,\n'
    printf '\tsetrgbf=\\E[38;2;%%p1%%d;%%p2%%d;%%p3%%dm,\n'
    printf '\tsetrgbb=\\E[48;2;%%p1%%d;%%p2%%d;%%p3%%dm,\n'
  } >>"$tmp"
  tic -x -o "$HOME/.terminfo" "$tmp" >/dev/null 2>&1 || true
  rm -f "$tmp"
}

apply_studio_pane_titles() {
  local target="${1:-}"
  local agent_label
  agent_label="$(agent_label_format)"

  if [[ -z "$target" ]]; then
    while IFS= read -r target; do
      [[ -n "$target" ]] || continue
      apply_studio_pane_titles "$target"
    done < <("$TMUX_BIN" list-windows -a -F '#{window_id}' 2>/dev/null || true)
    return 0
  fi

  "$TMUX_BIN" set-window-option -t "$target" -q pane-border-status top
  "$TMUX_BIN" set-window-option -t "$target" -q pane-border-format " #{pane_index} #{?@tt_note,#[fg=#e0af68]● #[default],}#[fg=#{?#{==:#{@tt_agent_kind},CLAUDE},#bb9af7,#{?#{==:#{@tt_agent_kind},CODEX},#7dcfff,#9ece6a}},bold]$agent_label#[default] #{?@tt_base_title,#{@tt_base_title},#{pane_title}} "
  "$TMUX_BIN" set-window-option -t "$target" -q pane-border-style "fg=#292e42,bg=default"
  "$TMUX_BIN" set-window-option -t "$target" -q pane-active-border-style "fg=#7aa2f7,bg=default"
}

clear_studio_pane_titles() {
  local target="${1:-}"

  if [[ -z "$target" ]]; then
    while IFS= read -r target; do
      [[ -n "$target" ]] || continue
      clear_studio_pane_titles "$target"
    done < <("$TMUX_BIN" list-windows -a -F '#{window_id}' 2>/dev/null || true)
    return 0
  fi

  "$TMUX_BIN" set-window-option -t "$target" -q pane-border-status off
}

set_agent_pane_title() {
  local target="${1:-}"
  shift || true
  local title="$*" path

  if [[ -z "$title" ]]; then
    title="$target"
    target="${TMUX_PANE:-}"
  fi
  [[ -n "$target" && -n "$title" ]] || { echo "usage: tt title [target] <short title>" >&2; exit 2; }

  "$TMUX_BIN" set-option -pt "$target" @tt_base_title "$title" 2>/dev/null || true
  path="$("$TMUX_BIN" display-message -p -t "$target" '#{pane_current_path}' 2>/dev/null || true)"
  set_pane_git_label "$target" "$path"
  "$TMUX_BIN" select-pane -t "$target" -T "$title" 2>/dev/null || true
  write_agent_cockpit_state "$(agent_cockpit_state_file)" --quiet
}

sync_agent_pane_context() {
  local target="${1:-${TMUX_PANE:-}}"
  local path

  [[ -n "$target" ]] || { echo "usage: tt sync [target|all]" >&2; exit 2; }

  if [[ "$target" == "all" ]]; then
    while IFS= read -r target; do
      [[ -n "$target" ]] || continue
      sync_agent_pane_context "$target"
    done < <("$TMUX_BIN" list-panes -a -F '#{pane_id}' 2>/dev/null || true)
    return 0
  fi

  path="$("$TMUX_BIN" display-message -p -t "$target" '#{pane_current_path}' 2>/dev/null || true)"
  set_pane_git_label "$target" "$path"
}

confirm_action() {
  local prompt="$1"
  local answer

  printf '%s [y/N]: ' "$prompt" >&2
  read -r answer
  case "$answer" in
    y|Y|yes|YES)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

kill_server() {
  local force="${1:-}"

  if [[ "$force" != "force" ]]; then
    confirm_action "kill tmux server and all sessions?" || exit 1
  fi

  "$TMUX_BIN" kill-server 2>/dev/null || true
}

create_plain() {
  local session="$1"

  ensure_tmux_default_shell

  if "$TMUX_BIN" has-session -t "$session" 2>/dev/null; then
    attach_or_switch "$session"
  fi

  if [[ -n "${TMUX:-}" ]]; then
    "$TMUX_BIN" new-session -d -s "$session"
    set_profile_metadata "$session" plain
    exec "$TMUX_BIN" switch-client -t "$session"
  fi

  "$TMUX_BIN" new-session -d -s "$session"
  set_profile_metadata "$session" plain
  exec "$TMUX_BIN" attach -t "$session"
}

first_window_id() {
  local session="$1"

  "$TMUX_BIN" list-windows -t "$session" -F '#{window_id}' 2>/dev/null | head -n 1
}

build_studio_layout() {
  local target="$1"
  local pane_command="${2:-}"
  local pane1 pane2 pane3

  if [[ -n "$pane_command" ]]; then
    pane1="$("$TMUX_BIN" list-panes -t "$target" -F '#{pane_id}' | head -n 1)"
    pane2="$("$TMUX_BIN" split-window -d -h -P -F '#{pane_id}' -t "$pane1" "$pane_command")"
    pane3="$("$TMUX_BIN" split-window -d -h -P -F '#{pane_id}' -t "$pane2" "$pane_command")"
    "$TMUX_BIN" select-layout -t "$target" even-horizontal
    "$TMUX_BIN" split-window -d -v -t "$pane1" "$pane_command"
    "$TMUX_BIN" split-window -d -v -t "$pane2" "$pane_command"
    "$TMUX_BIN" split-window -d -v -t "$pane3" "$pane_command"
    return
  else
    "$TMUX_BIN" split-window -h -t "$target"
    "$TMUX_BIN" split-window -h -t "$target"
  fi
  "$TMUX_BIN" select-layout -t "$target" even-horizontal

  while IFS= read -r pane; do
    if [[ -n "$pane_command" ]]; then
      "$TMUX_BIN" split-window -d -v -t "$pane" "$pane_command"
    else
      "$TMUX_BIN" split-window -v -t "$pane"
    fi
  done < <("$TMUX_BIN" list-panes -t "$target" -F '#{pane_id}')
}

label_grid_window() {
  local target="$1"
  local label="$2"
  local pane index
  local -a commands

  apply_studio_pane_titles "$target"

  index=1
  while IFS= read -r pane; do
    [[ -n "$pane" ]] || continue
    commands+=(select-pane -t "$pane" -T "$label.$index" \;)
    index=$((index + 1))
  done < <("$TMUX_BIN" list-panes -t "$target" -F '#{pane_id}')

  if (( ${#commands[@]} )); then
    "$TMUX_BIN" "${commands[@]}" 2>/dev/null || true
  fi
}

refresh_ops_labels() {
  local session="$1"
  local window_id window_name

  while IFS=$'\t' read -r window_id window_name; do
    [[ -n "$window_id" && -n "$window_name" ]] || continue
    case "$window_name" in
      ops|L1|L2|L3)
        label_grid_window "$window_id" "$window_name"
        ;;
    esac
  done < <("$TMUX_BIN" list-windows -t "$session" -F '#{window_id}	#W' 2>/dev/null)
}

upgrade_ops_shells() {
  local session="$1"
  local current_command cwd pane shell_command window_id

  ensure_tmux_default_shell
  shell_command="$(default_login_shell_command)"

  while IFS= read -r window_id; do
    [[ -n "$window_id" ]] || continue
    while IFS=$'\t' read -r pane current_command cwd; do
      [[ -n "$pane" ]] || continue
      case "$current_command" in
        zsh|bash|fish|sh)
          "$TMUX_BIN" respawn-pane -k -t "$pane" -c "$cwd" "$shell_command" 2>/dev/null || true
          ;;
      esac
    done < <("$TMUX_BIN" list-panes -t "$window_id" -F '#{pane_id}	#{pane_current_command}	#{pane_current_path}')
  done < <("$TMUX_BIN" list-windows -t "$session" -F '#{window_id}')
}

schedule_ops_shell_upgrade() {
  local session="$1"
  local self

  self="$(tt_self_command)"
  "$TMUX_BIN" run-shell -b "$self upgrade-ops-shells $(shell_quote "$session")" 2>/dev/null || true
}

ops_session_valid() {
  local session="$1"
  local window_count bad_count window_id window_name

  window_count="$("$TMUX_BIN" list-windows -t "$session" -F '#W' 2>/dev/null | wc -l | tr -d ' ')"
  [[ "$window_count" == "4" ]] || return 1

  bad_count="$("$TMUX_BIN" list-windows -t "$session" -F '#W #{window_panes}' 2>/dev/null | awk '
    $1 !~ /^(ops|L[123])$/ || $2 != 6 { bad++ }
    { seen[$1]++ }
    END {
      if (seen["ops"] != 1 || seen["L1"] != 1 || seen["L2"] != 1 || seen["L3"] != 1) bad++
      print bad + 0
    }')"
  [[ "$bad_count" == "0" ]] || return 1

  while IFS=$'\t' read -r window_id window_name; do
    [[ -n "$window_id" && -n "$window_name" ]] || return 1
    "$TMUX_BIN" list-panes -t "$window_id" -F '#{pane_left} #{pane_top}' 2>/dev/null | awk '
      { count++; left[$1]=1; top[$2]=1 }
      END {
        for (x in left) left_count++
        for (y in top) top_count++
        exit !(count == 6 && left_count == 3 && top_count == 2)
      }' || return 1
  done < <("$TMUX_BIN" list-windows -t "$session" -F '#{window_id}	#W' 2>/dev/null)
}

ops_session_idle() {
  local session="$1"

  "$TMUX_BIN" list-panes -t "$session" -F '#{pane_current_command}' 2>/dev/null |
    awk 'BEGIN { ok=1 } $0 !~ /^(zsh|bash|fish|sh)$/ { ok=0 } END { exit ok ? 0 : 1 }'
}

create_ops() {
  local session="${1:-cockpit}"
  local start_dir="${2:-$PWD}"

  create_ops_detached "$session" "$start_dir"
  attach_or_switch "$session"
}

create_ops_detached() {
  local session="${1:-cockpit}"
  local start_dir="${2:-$PWD}"
  local skip_shell_upgrade="${3:-}"
  local window window_id bootstrap_command width height

  case "$session" in
    ""|--)
      session="cockpit"
      ;;
    -*)
      echo "tt: invalid ops session name '$session'" >&2
      exit 2
      ;;
  esac

  ensure_tmux_default_shell
  bootstrap_command="$(default_login_shell_command)"
  width="${TT_OPS_WIDTH:-240}"
  height="${TT_OPS_HEIGHT:-80}"

  if [[ "$session" == "cockpit" ]] &&
    "$TMUX_BIN" has-session -t ops 2>/dev/null &&
    ! "$TMUX_BIN" has-session -t cockpit 2>/dev/null; then
    if ops_session_idle ops; then
      "$TMUX_BIN" kill-session -t ops 2>/dev/null || true
    else
      echo "tt: old session 'ops' is active; not replacing it with 'cockpit'" >&2
      echo "tt: finish or rename that session, then run 'tt cockpit' again" >&2
      exit 2
    fi
  fi

  if "$TMUX_BIN" has-session -t "$session" 2>/dev/null; then
    if ops_session_valid "$session"; then
      refresh_ops_labels "$session"
      schedule_ops_shell_upgrade "$session"
      attach_or_switch "$session"
    fi
    if ops_session_idle "$session"; then
      "$TMUX_BIN" kill-session -t "$session" 2>/dev/null || true
    else
      echo "tt: session '$session' has a non-ops layout and active commands; not rebuilding it" >&2
      echo "tt: kill or rename that session, then run 'tt ops' again" >&2
      exit 2
    fi
  fi

  if "$TMUX_BIN" has-session -t "$session" 2>/dev/null; then
    attach_or_switch "$session"
  fi

  window_id="$("$TMUX_BIN" new-session -d -x "$width" -y "$height" -P -F '#{window_id}' -s "$session" -n ops -c "$start_dir" "$bootstrap_command")"
  set_profile_metadata "$session" ops
  build_studio_layout "$window_id" "$bootstrap_command"
  label_grid_window "$window_id" ops

  for window in L1 L2 L3; do
    "$TMUX_BIN" new-window -d -t "$session:" -n "$window" -c "$start_dir" "$bootstrap_command"
    window_id="$session:$window"
    build_studio_layout "$window_id" "$bootstrap_command"
    label_grid_window "$window_id" "$window"
  done

  if [[ "$skip_shell_upgrade" != "--no-shell-upgrade" ]]; then
    schedule_ops_shell_upgrade "$session"
  fi
  "$TMUX_BIN" select-window -t "$window_id"
}

ensure_studio_layout() {
  local session="$1"
  local start_dir="${2:-}"
  local window_id pane_count shell_command

  ensure_tmux_default_shell
  shell_command="$(default_login_shell_command)"

  if ! "$TMUX_BIN" has-session -t "$session" 2>/dev/null; then
    if [[ -n "$start_dir" ]]; then
      "$TMUX_BIN" new-session -d -s "$session" -n main -c "$start_dir" "$shell_command"
    else
      "$TMUX_BIN" new-session -d -s "$session" -n main "$shell_command"
    fi
  fi

  set_profile_metadata "$session" studio

  window_id="$(first_window_id "$session")"
  [[ -n "$window_id" ]] || return 1
  pane_count="$("$TMUX_BIN" list-panes -t "$window_id" 2>/dev/null | wc -l | tr -d ' ')"

  case "$pane_count" in
    1)
      build_studio_layout "$window_id" "$shell_command"
      apply_studio_pane_titles "$window_id"
      ;;
    6)
      apply_studio_pane_titles "$window_id"
      ;;
    *)
      echo "tt: session '$session' has $pane_count panes; refusing to reshape non-empty layout" >&2
      echo "tt: use 'tt reset ai $session' if you want to replace it" >&2
      ;;
  esac
}

create_studio() {
  local session="$1"

  ensure_studio_layout "$session"
  install_agent_autosave_hooks
  write_agent_cockpit_state "$(agent_cockpit_state_file)" --quiet

  attach_or_switch "$session"
}

create_studio_detached() {
  local session="$1"
  local start_dir="${2:-$HOME}"

  ensure_studio_layout "$session" "$start_dir"
  install_agent_autosave_hooks
}

create_mobile() {
  local session="$1"

  if "$TMUX_BIN" has-session -t "$session" 2>/dev/null; then
    attach_or_switch "$session"
  fi

  if [[ -n "${TMUX:-}" ]]; then
    "$TMUX_BIN" new-session -d -s "$session"
    set_profile_metadata "$session" mobile
    "$TMUX_BIN" set-option -t "$session" -q status off
    exec "$TMUX_BIN" switch-client -t "$session"
  fi

  "$TMUX_BIN" new -d -s "$session"
  set_profile_metadata "$session" mobile
  "$TMUX_BIN" set-option -t "$session" -q status off
  exec "$TMUX_BIN" attach -t "$session"
}

mobile_target_label() {
  local target="$1"
  local session="$2"
  local window="$3"
  local pane="$4"
  local active="$5"
  local command="$6"
  local title="$7"
  local path="$8"
  local window_name="$9"
  local active_mark detail_label path_label

  active_mark=" "
  [[ "$active" == "*" ]] && active_mark="*"

  detail_label="$title"
  if [[ -z "$detail_label" || "$detail_label" == "$path" ]]; then
    detail_label="$window_name"
  fi
  if [[ -z "$detail_label" ]]; then
    detail_label="$command"
  fi

  path_label="${path/#$HOME/~}"
  if [[ "$path_label" == "$HOME" || "$path_label" == "~" ]]; then
    path_label="~"
  elif [[ "$path_label" == ~/*/*/* ]]; then
    path_label=".../${path_label##*/}"
  fi

  printf '%s\x1f%s [%s] %s.%s  %s  %s\n' \
    "$target" \
    "$active_mark" \
    "$session" \
    "$window" \
    "$pane" \
    "$detail_label" \
    "$path_label"
}

choose_mobile_option() {
  local selection sep
  local -a options=()
  sep=$'\x1f'

  options=("$@")

  if command -v fzf >/dev/null 2>&1; then
    selection="$(printf '%s\n' "${options[@]}" | fzf \
      --prompt='mtt > ' \
      --height=55% \
      --layout=reverse \
      --border \
      --delimiter="$sep" \
      --with-nth=2 \
      --header='pick a pane')"
    [[ -n "$selection" ]] || return 130
    printf '%s\n' "$selection"
    return 0
  fi

  local choice
  local -a labels=()
  for choice in "${options[@]}"; do
    labels+=("${choice#*"$sep"}")
  done

  PS3="mtt> "
  select choice in "${labels[@]}"; do
    [[ -n "${choice:-}" ]] || continue
    printf '%s\n' "${options[REPLY-1]}"
    return 0
  done
}

mobile_choose_pane_target() {
  local selection sep pane_format
  local -a options=()
  sep=$'\x1f'
  pane_format="#{session_name}${sep}#{@tt_profile}${sep}#{window_index}${sep}#{pane_index}${sep}#{?pane_active,*, }${sep}#{pane_current_command}${sep}#{pane_title}${sep}#{pane_current_path}${sep}#{window_name}"

  while IFS="$sep" read -r session profile window pane active command title path window_name; do
    [[ -n "$session" ]] || continue
    [[ "$profile" == "mobile" ]] && continue
    options+=("$(mobile_target_label "$session:$window.$pane" "$session" "$window" "$pane" "$active" "$command" "$title" "$path" "$window_name")")
  done < <("$TMUX_BIN" list-panes -a -F "$pane_format" 2>/dev/null || true)

  if [[ ${#options[@]} -eq 0 ]]; then
    return 1
  fi

  if ! selection="$(choose_mobile_option "${options[@]}")"; then
    return 130
  fi

  printf '%s\n' "${selection%%"$sep"*}"
}

ensure_mobile_group_session() {
  local source_session="$1"
  local mobile_session

  mobile_session="$(mobile_group_session_name "$source_session")"
  if ! "$TMUX_BIN" has-session -t "$mobile_session" 2>/dev/null; then
    "$TMUX_BIN" new-session -d -t "$source_session" -s "$mobile_session"
  fi

  set_profile_metadata "$mobile_session" mobile
  "$TMUX_BIN" set-option -t "$mobile_session" -q status off
  printf '%s\n' "$mobile_session"
}

attach_mobile_target() {
  local target="$1"
  local source_session target_suffix

  source_session="${target%%:*}"
  target_suffix="${target#*:}"

  if [[ -n "${TMUX:-}" ]]; then
    "$TMUX_BIN" refresh-client -f active-pane,ignore-size 2>/dev/null || true
    "$TMUX_BIN" switch-client -t "$source_session"
    "$TMUX_BIN" select-window -t "$source_session:${target_suffix%.*}"
    exec "$TMUX_BIN" select-pane -t "$source_session:$target_suffix"
  fi

  exec "$TMUX_BIN" attach -f active-pane,ignore-size -t "$source_session" \; \
    select-window -t "$source_session:${target_suffix%.*}" \; \
    select-pane -t "$source_session:$target_suffix"
}

restore_windows() {
  local target="${1:-}"
  local window_id
  local -a target_args=()

  [[ -n "$target" ]] && target_args=(-t "$target")

  while IFS= read -r window_id; do
    [[ -n "$window_id" ]] || continue
    "$TMUX_BIN" resize-pane -Z -t "$window_id"
  done < <("$TMUX_BIN" list-windows "${target_args[@]}" -F '#{?window_zoomed_flag,#{window_id},}' 2>/dev/null | sort -u || true)
}

restore_studio_layout() {
  local target="${1:-}"
  local manifest
  local window_id pane_count
  local -a target_args=()

  [[ -n "$target" ]] && target_args=(-t "$target")

  manifest="$(agent_cockpit_manifest)"
  apply_agent_manifest_metadata "$manifest"
  restore_windows "$target"

  while IFS= read -r window_id; do
    [[ -n "$window_id" ]] || continue
    pane_count="$("$TMUX_BIN" list-panes -t "$window_id" 2>/dev/null | wc -l | tr -d ' ')"
    if [[ "$pane_count" == "6" ]]; then
      apply_studio_pane_titles "$window_id"
    fi
  done < <("$TMUX_BIN" list-windows "${target_args[@]}" -F '#{window_id}' 2>/dev/null | sort -u || true)

  install_agent_autosave_hooks
  write_agent_cockpit_state "$(agent_cockpit_state_file)" --quiet
}

agent_cockpit_manifest() {
  local home_manifest="${XDG_CONFIG_HOME:-$HOME/.config}/tt/agent-cockpit.tsv"
  local dotfiles_manifest="$DOTFILES_DIR/.config/tt/agent-cockpit.tsv"
  local state_manifest
  state_manifest="$(agent_cockpit_state_file)"

  if [[ -n "${TT_AGENT_COCKPIT_MANIFEST:-}" ]]; then
    printf '%s\n' "$TT_AGENT_COCKPIT_MANIFEST"
  elif manifest_has_entries "$state_manifest"; then
    printf '%s\n' "$state_manifest"
  elif manifest_has_entries "$home_manifest"; then
    printf '%s\n' "$home_manifest"
  else
    printf '%s\n' "$dotfiles_manifest"
  fi
}

agent_cockpit_seed_manifest() {
  local home_manifest="${XDG_CONFIG_HOME:-$HOME/.config}/tt/agent-cockpit.tsv"
  local dotfiles_manifest="$DOTFILES_DIR/.config/tt/agent-cockpit.tsv"

  if [[ -n "${TT_AGENT_COCKPIT_MANIFEST:-}" && -f "$TT_AGENT_COCKPIT_MANIFEST" ]]; then
    printf '%s\n' "$TT_AGENT_COCKPIT_MANIFEST"
  elif manifest_has_entries "$home_manifest"; then
    printf '%s\n' "$home_manifest"
  else
    printf '%s\n' "$dotfiles_manifest"
  fi
}

manifest_has_entries() {
  local manifest="$1"

  [[ -f "$manifest" ]] || return 1
  awk -F '\t' '$1 != "" && $1 !~ /^#/ { found=1 } END { exit found ? 0 : 1 }' "$manifest"
}

agent_cockpit_state_file() {
  local state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
  printf '%s\n' "$state_home/tt/agent-cockpit.tsv"
}

codex_cockpit_snapshot_file() {
  local state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
  printf '%s\n' "$state_home/tt/codex-cockpit.tsv"
}

codex_cockpit_timer_pid_file() {
  local state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
  printf '%s\n' "$state_home/tt/codex-cockpit.timer.pid"
}

pane_notes_dir() {
  local state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
  printf '%s\n' "$state_home/tt/pane-notes"
}

pane_markers_dir() {
  local state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
  printf '%s\n' "$state_home/tt/pane-markers"
}

sanitize_filename_component() {
  tr -cs 'A-Za-z0-9._-' '-' | sed 's/^-//; s/-$//; s/--*/-/g'
}

pane_note_metadata() {
  local target="${1:-${TMUX_PANE:-}}"
  local session window pane cwd base_title pane_title title key hash slug dir file

  [[ -n "$target" ]] || { echo "pane target required" >&2; return 2; }
  IFS=$'\t' read -r session window pane cwd base_title pane_title < <(
    "$TMUX_BIN" display-message -p -t "$target" '#{session_name}	#{window_index}	#{pane_index}	#{pane_current_path}	#{@tt_base_title}	#{pane_title}' 2>/dev/null || true
  )
  [[ -n "$session" && -n "$window" && -n "$pane" ]] || { echo "pane not found: $target" >&2; return 1; }

  title="${base_title:-$pane_title}"
  title="${title//$'\t'/ }"
  title="${title//$'\n'/ }"
  cwd="${cwd//$'\t'/ }"
  cwd="${cwd//$'\n'/ }"
  key="${session}"$'\t'"${window}"$'\t'"${pane}"
  hash="$(printf '%s' "$key" | shasum -a 256 | awk '{print substr($1, 1, 16)}')"
  slug="$(printf '%s-w%s-p%s' "$session" "$window" "$pane" | sanitize_filename_component | cut -c 1-80)"
  [[ -n "$slug" ]] || slug="pane"
  dir="$(pane_notes_dir)"
  file="$dir/$slug-$hash.md"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$session" "$window" "$pane" "$cwd" "$title" "$hash" "$file"
}

pane_marker_metadata() {
  local target="${1:-${TMUX_PANE:-}}"
  local session window pane cwd title hash note_file slug dir file
  IFS=$'\t' read -r session window pane cwd title hash note_file < <(pane_note_metadata "$target")
  [[ -n "${hash:-}" ]] || return 1
  slug="$(printf '%s-w%s-p%s' "$session" "$window" "$pane" | sanitize_filename_component | cut -c 1-80)"
  [[ -n "$slug" ]] || slug="pane"
  dir="$(pane_markers_dir)"
  file="$dir/$slug-$hash.md"
  printf '%s\t%s\t%s\t%s\t%s\t%s\t%s\n' "$session" "$window" "$pane" "$cwd" "$title" "$hash" "$file"
}

pane_note_frontmatter_matches() {
  local file="$1" session="$2" window="$3" pane="$4"
  [[ -f "$file" ]] || return 1
  grep -qx "session: \"$session\"" "$file" 2>/dev/null &&
    grep -qx "window: \"$window\"" "$file" 2>/dev/null &&
    grep -qx "pane: \"$pane\"" "$file" 2>/dev/null
}

resolve_pane_note_file() {
  local target="$1" expected="$2" session="$3" window="$4" pane="$5"
  local current dir candidate

  [[ -n "$expected" ]] || return 1
  if [[ -f "$expected" ]]; then
    printf '%s\n' "$expected"
    return 0
  fi

  current="$("$TMUX_BIN" show-option -pt "$target" -qv @tt_note_file 2>/dev/null || true)"
  if [[ -n "$current" && -f "$current" && "$current" != "$expected" ]]; then
    mkdir -p "$(dirname "$expected")"
    mv "$current" "$expected" 2>/dev/null || cp "$current" "$expected"
    printf '%s\n' "$expected"
    return 0
  fi

  dir="$(pane_notes_dir)"
  if [[ -d "$dir" ]]; then
    while IFS= read -r candidate; do
      [[ -n "$candidate" && "$candidate" != "$expected" ]] || continue
      if pane_note_frontmatter_matches "$candidate" "$session" "$window" "$pane"; then
        mkdir -p "$(dirname "$expected")"
        mv "$candidate" "$expected" 2>/dev/null || cp "$candidate" "$expected"
        printf '%s\n' "$expected"
        return 0
      fi
    done < <(find "$dir" -maxdepth 1 -type f -name '*.md' 2>/dev/null | sort)
  fi

  printf '%s\n' "$expected"
}

resolve_pane_marker_file() {
  local target="$1" expected="$2" session="$3" window="$4" pane="$5"
  local current dir candidate

  [[ -n "$expected" ]] || return 1
  if [[ -f "$expected" ]]; then
    printf '%s\n' "$expected"
    return 0
  fi

  current="$("$TMUX_BIN" show-option -pt "$target" -qv @tt_marker_file 2>/dev/null || true)"
  if [[ -n "$current" && -f "$current" && "$current" != "$expected" ]]; then
    mkdir -p "$(dirname "$expected")"
    mv "$current" "$expected" 2>/dev/null || cp "$current" "$expected"
    printf '%s\n' "$expected"
    return 0
  fi

  dir="$(pane_markers_dir)"
  if [[ -d "$dir" ]]; then
    while IFS= read -r candidate; do
      [[ -n "$candidate" && "$candidate" != "$expected" ]] || continue
      if pane_note_frontmatter_matches "$candidate" "$session" "$window" "$pane"; then
        mkdir -p "$(dirname "$expected")"
        mv "$candidate" "$expected" 2>/dev/null || cp "$candidate" "$expected"
        printf '%s\n' "$expected"
        return 0
      fi
    done < <(find "$dir" -maxdepth 1 -type f -name '*.md' 2>/dev/null | sort)
  fi

  printf '%s\n' "$expected"
}

write_pane_note_file() {
  local file="$1" session="$2" window="$3" pane="$4" cwd="$5" title="$6" hash="$7" body="${8:-}"
  local updated
  updated="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  mkdir -p "$(dirname "$file")"
  {
    printf -- '---\n'
    printf 'session: "%s"\n' "$session"
    printf 'window: "%s"\n' "$window"
    printf 'pane: "%s"\n' "$pane"
    printf 'cwd: "%s"\n' "$cwd"
    printf 'title: "%s"\n' "$title"
    printf 'key_hash: "%s"\n' "$hash"
    printf 'updated: "%s"\n' "$updated"
    printf -- '---\n\n'
    if [[ -n "$body" ]]; then
      printf '%s\n' "$body"
    fi
  } > "$file"
}

pane_marker_color() {
  case "${1:-}" in
    amber) printf '#e0af68\n' ;;
    green) printf '#9ece6a\n' ;;
    blue) printf '#7aa2f7\n' ;;
    dim) printf '#565f89\n' ;;
    *) printf '#565f89\n' ;;
  esac
}

pane_marker_window_style() {
  case "${1:-}" in
    amber) printf 'fg=default,bg=#211d17\n' ;;
    green) printf 'fg=default,bg=#182318\n' ;;
    blue) printf 'fg=default,bg=#171f2b\n' ;;
    dim) printf 'fg=#565f89,bg=#11121a\n' ;;
    *) printf '\n' ;;
  esac
}

pane_marker_active_style() {
  case "${1:-}" in
    amber) printf 'fg=default,bg=#292218\n' ;;
    green) printf 'fg=default,bg=#1f2a1f\n' ;;
    blue) printf 'fg=default,bg=#1d2736\n' ;;
    dim) printf 'fg=#565f89,bg=#11121a\n' ;;
    *) printf '\n' ;;
  esac
}

apply_pane_marker_style() {
  local target="${1:-${TMUX_PANE:-}}"
  local marker="${2:-default}"
  local color style active_style

  case "$marker" in
    default|clear|none|'')
      "$TMUX_BIN" set-option -pt "$target" -qu @tt_marker 2>/dev/null || true
      "$TMUX_BIN" set-option -pt "$target" -qu @tt_marker_color 2>/dev/null || true
      "$TMUX_BIN" set-option -pt "$target" -qu @tt_marker_file 2>/dev/null || true
      "$TMUX_BIN" set-option -pt "$target" -qu window-style 2>/dev/null || true
      "$TMUX_BIN" set-option -pt "$target" -qu window-active-style 2>/dev/null || true
      return 0
      ;;
    amber|green|blue|dim)
      ;;
    *)
      echo "unknown pane marker: $marker" >&2
      return 2
      ;;
  esac

  color="$(pane_marker_color "$marker")"
  style="$(pane_marker_window_style "$marker")"
  active_style="$(pane_marker_active_style "$marker")"
  "$TMUX_BIN" set-option -pt "$target" @tt_marker "$marker" 2>/dev/null || true
  "$TMUX_BIN" set-option -pt "$target" @tt_marker_color "$color" 2>/dev/null || true
  "$TMUX_BIN" set-option -pt "$target" window-style "$style" 2>/dev/null || true
  "$TMUX_BIN" set-option -pt "$target" window-active-style "$active_style" 2>/dev/null || true
}

write_pane_marker_file() {
  local file="$1" session="$2" window="$3" pane="$4" cwd="$5" title="$6" hash="$7" marker="$8"
  local updated color
  updated="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  color="$(pane_marker_color "$marker")"
  mkdir -p "$(dirname "$file")"
  {
    printf -- '---\n'
    printf 'session: "%s"\n' "$session"
    printf 'window: "%s"\n' "$window"
    printf 'pane: "%s"\n' "$pane"
    printf 'cwd: "%s"\n' "$cwd"
    printf 'title: "%s"\n' "$title"
    printf 'key_hash: "%s"\n' "$hash"
    printf 'marker: "%s"\n' "$marker"
    printf 'color: "%s"\n' "$color"
    printf 'updated: "%s"\n' "$updated"
    printf -- '---\n\n'
    printf '%s\n' "$marker"
  } > "$file"
}

pane_marker_from_file() {
  local file="$1"
  awk -F '"' '/^marker: "/ { print $2; exit }' "$file"
}

set_pane_marker() {
  local target="${1:-${TMUX_PANE:-}}"
  local marker="${2:-default}"
  local session window pane cwd title hash file

  IFS=$'\t' read -r session window pane cwd title hash file < <(pane_marker_metadata "$target")
  [[ -n "${file:-}" ]] || return 1
  file="$(resolve_pane_marker_file "$target" "$file" "$session" "$window" "$pane")"

  case "$marker" in
    default|clear|none|'')
      rm -f "$file"
      apply_pane_marker_style "$target" default
      ;;
    amber|green|blue|dim)
      write_pane_marker_file "$file" "$session" "$window" "$pane" "$cwd" "$title" "$hash" "$marker"
      apply_pane_marker_style "$target" "$marker"
      "$TMUX_BIN" set-option -pt "$target" @tt_marker_file "$file" 2>/dev/null || true
      ;;
    *)
      echo "usage: tt marker set <pane> [default|amber|green|blue|dim]" >&2
      return 2
      ;;
  esac

  apply_studio_pane_titles "$("$TMUX_BIN" display-message -p -t "$target" '#{window_id}' 2>/dev/null || true)"
}

sync_pane_marker() {
  local target="${1:-${TMUX_PANE:-}}"
  local session window pane cwd title hash file marker current

  IFS=$'\t' read -r session window pane cwd title hash file < <(pane_marker_metadata "$target")
  [[ -n "${file:-}" ]] || return 1
  file="$(resolve_pane_marker_file "$target" "$file" "$session" "$window" "$pane")"
  if [[ -f "$file" ]]; then
    marker="$(pane_marker_from_file "$file")"
    apply_pane_marker_style "$target" "$marker"
    "$TMUX_BIN" set-option -pt "$target" @tt_marker_file "$file" 2>/dev/null || true
  else
    current="$("$TMUX_BIN" show-option -pt "$target" -qv @tt_marker 2>/dev/null || true)"
    [[ -z "$current" ]] || apply_pane_marker_style "$target" default
  fi
}

sync_pane_markers() {
  local target="${1:-all}"
  if [[ "$target" == "all" ]]; then
    while IFS= read -r target; do
      [[ -n "$target" ]] || continue
      sync_pane_marker "$target" || true
    done < <("$TMUX_BIN" list-panes -a -F '#{pane_id}' 2>/dev/null || true)
    apply_studio_pane_titles
    return 0
  fi
  sync_pane_marker "$target"
}

list_pane_markers() {
  local dir file
  dir="$(pane_markers_dir)"
  if [[ ! -d "$dir" ]]; then
    echo "no pane markers: $dir" >&2
    return 1
  fi
  while IFS= read -r file; do
    [[ -n "$file" ]] || continue
    printf '%s\t%s\n' "$file" "$(pane_marker_from_file "$file")"
  done < <(find "$dir" -maxdepth 1 -type f -name '*.md' | sort)
}

note_summary_from_file() {
  local file="$1"
  awk '
    NR == 1 && /^---[[:space:]]*$/ { front = 1; next }
    front == 1 && /^---[[:space:]]*$/ { front = 2; next }
    front == 1 { next }
    front == 0 || front >= 2 {
      if (!NF || $0 ~ /^<!--/ || $0 ~ /^```/) next
      line = $0
      sub(/^#[[:space:]]*/, "", line)
      if (length(line) > 60) line = substr(line, 1, 57) "..."
      print line
      exit
    }
  ' "$file"
}

sync_pane_note() {
  local target="${1:-${TMUX_PANE:-}}"
  local session window pane cwd title hash file summary
  IFS=$'\t' read -r session window pane cwd title hash file < <(pane_note_metadata "$target")
  [[ -n "${file:-}" ]] || return 1
  file="$(resolve_pane_note_file "$target" "$file" "$session" "$window" "$pane")"

  summary="$([[ -s "$file" ]] && note_summary_from_file "$file" || true)"
  if [[ -n "$summary" ]]; then
    "$TMUX_BIN" set-option -pt "$target" @tt_note "$summary" 2>/dev/null || true
    "$TMUX_BIN" set-option -pt "$target" @tt_note_file "$file" 2>/dev/null || true
  else
    "$TMUX_BIN" set-option -pt "$target" -u @tt_note 2>/dev/null || true
    "$TMUX_BIN" set-option -pt "$target" -u @tt_note_file 2>/dev/null || true
  fi
}

sync_pane_notes() {
  local target="${1:-all}"
  if [[ "$target" == "all" ]]; then
    while IFS= read -r target; do
      [[ -n "$target" ]] || continue
      sync_pane_note "$target" || true
    done < <("$TMUX_BIN" list-panes -a -F '#{pane_id}' 2>/dev/null || true)
    return 0
  fi
  sync_pane_note "$target"
}

set_pane_note() {
  local target="${1:-${TMUX_PANE:-}}"
  shift || true
  local note="$*"
  local session window pane cwd title hash file

  [[ -n "$target" ]] || { echo "usage: tt note set <pane> <note>" >&2; return 2; }
  IFS=$'\t' read -r session window pane cwd title hash file < <(pane_note_metadata "$target")
  [[ -n "${file:-}" ]] || return 1
  file="$(resolve_pane_note_file "$target" "$file" "$session" "$window" "$pane")"

  if [[ -z "$note" ]]; then
    clear_pane_note "$target"
    return
  fi

  write_pane_note_file "$file" "$session" "$window" "$pane" "$cwd" "$title" "$hash" "$note"
  sync_pane_note "$target"
  apply_studio_pane_titles "$("$TMUX_BIN" display-message -p -t "$target" '#{window_id}' 2>/dev/null || true)"
}

clear_pane_note() {
  local target="${1:-${TMUX_PANE:-}}"
  local session window pane cwd title hash file
  IFS=$'\t' read -r session window pane cwd title hash file < <(pane_note_metadata "$target")
  [[ -n "${file:-}" ]] || return 1
  file="$(resolve_pane_note_file "$target" "$file" "$session" "$window" "$pane")"
  rm -f "$file"
  "$TMUX_BIN" set-option -pt "$target" -u @tt_note 2>/dev/null || true
  "$TMUX_BIN" set-option -pt "$target" -u @tt_note_file 2>/dev/null || true
  apply_studio_pane_titles "$("$TMUX_BIN" display-message -p -t "$target" '#{window_id}' 2>/dev/null || true)"
}

show_pane_note() {
  local target="${1:-${TMUX_PANE:-}}"
  local session window pane cwd title hash file
  IFS=$'\t' read -r session window pane cwd title hash file < <(pane_note_metadata "$target")
  [[ -n "${file:-}" ]] || return 1
  file="$(resolve_pane_note_file "$target" "$file" "$session" "$window" "$pane")"
  if [[ -f "$file" ]]; then
    printf '%s:%s.%s  %s\n\n' "$session" "$window" "$pane" "$title"
    awk '
      NR == 1 && /^---[[:space:]]*$/ { front = 1; next }
      front == 1 && /^---[[:space:]]*$/ { front = 2; next }
      front == 1 { next }
      { print; seen = 1 }
      END {
        if (!seen) print "(empty note)"
      }
    ' "$file"
  else
    printf 'no note for %s:%s.%s %s\n' "$session" "$window" "$pane" "$title"
  fi
}

edit_pane_note() {
  local target="${1:-${TMUX_PANE:-}}"
  local session window pane cwd title hash file editor
  IFS=$'\t' read -r session window pane cwd title hash file < <(pane_note_metadata "$target")
  [[ -n "${file:-}" ]] || return 1
  file="$(resolve_pane_note_file "$target" "$file" "$session" "$window" "$pane")"
  if [[ ! -f "$file" ]]; then
    write_pane_note_file "$file" "$session" "$window" "$pane" "$cwd" "$title" "$hash"
  fi
  editor="${VISUAL:-${EDITOR:-nano}}"
  "$editor" "$file"
  sync_pane_note "$target"
  apply_studio_pane_titles "$("$TMUX_BIN" display-message -p -t "$target" '#{window_id}' 2>/dev/null || true)"
}

prompt_pane_note() {
  local target="${1:-${TMUX_PANE:-}}"
  local current note session window pane cwd title hash file
  IFS=$'\t' read -r session window pane cwd title hash file < <(pane_note_metadata "$target")
  current="$("$TMUX_BIN" show-option -pt "$target" -qv @tt_note 2>/dev/null || true)"
  printf 'pane note: %s:%s.%s  %s\n' "$session" "$window" "$pane" "$title"
  [[ -n "$current" ]] && printf 'current: %s\n' "$current"
  printf 'blank clears. note> '
  IFS= read -r note
  if [[ -z "$note" ]]; then
    clear_pane_note "$target"
  else
    set_pane_note "$target" "$note"
  fi
}

list_pane_notes() {
  local dir file
  dir="$(pane_notes_dir)"
  if [[ ! -d "$dir" ]]; then
    echo "no pane notes: $dir" >&2
    return 1
  fi
  while IFS= read -r file; do
    [[ -n "$file" ]] || continue
    printf '%s\t%s\n' "$file" "$(note_summary_from_file "$file")"
  done < <(find "$dir" -maxdepth 1 -type f -name '*.md' | sort)
}

snapshot_history_dir() {
  local label="$1"
  local state_home="${XDG_STATE_HOME:-$HOME/.local/state}"
  printf '%s\n' "$state_home/tt/history/$label"
}

record_snapshot_history() {
  local source="$1"
  local label="$2"
  local max="${TT_SNAPSHOT_HISTORY_MAX:-864}"
  local dir ts dest newest file count
  local -a files=()

  [[ -f "$source" ]] || return 0
  case "$max" in
    ''|*[!0-9]*)
      max=864
      ;;
  esac
  (( max > 0 )) || return 0

  dir="$(snapshot_history_dir "$label")"
  mkdir -p "$dir"
  newest="$(ls -1t "$dir"/*.tsv 2>/dev/null | head -n 1 || true)"
  if [[ -n "$newest" ]] && cmp -s "$source" "$newest"; then
    return 0
  fi

  ts="$(date -u +%Y%m%dT%H%M%SZ)"
  dest="$dir/$ts.tsv"
  if [[ -e "$dest" ]]; then
    dest="$dir/$ts.$$.tsv"
  fi
  cp "$source" "$dest"

  while IFS= read -r file; do
    [[ -n "$file" ]] && files+=("$file")
  done < <(ls -1t "$dir"/*.tsv 2>/dev/null || true)

  count=0
  for file in "${files[@]}"; do
    count=$((count + 1))
    if (( count > max )); then
      rm -f "$file"
    fi
  done
}

list_snapshot_history() {
  local label="${1:-codex-cockpit}"
  local dir max="${2:-40}"
  local count=0 file

  dir="$(snapshot_history_dir "$label")"
  if [[ ! -d "$dir" ]]; then
    echo "no snapshot history: $dir" >&2
    return 1
  fi

  while IFS= read -r file; do
    [[ -n "$file" ]] || continue
    printf '%s\n' "$file"
    count=$((count + 1))
    (( count >= max )) && break
  done < <(ls -1t "$dir"/*.tsv 2>/dev/null || true)
  return 0
}

count_snapshot_history() {
  local label="${1:-codex-cockpit}"
  local dir
  dir="$(snapshot_history_dir "$label")"
  find "$dir" -maxdepth 1 -type f -name '*.tsv' 2>/dev/null | wc -l | tr -d ' '
}

file_age_seconds() {
  local file="$1"
  local now mtime
  [[ -f "$file" ]] || return 1
  now="$(date +%s)"
  mtime="$(stat -f %m "$file" 2>/dev/null || stat -c %Y "$file" 2>/dev/null || true)"
  [[ "$mtime" =~ ^[0-9]+$ ]] || return 1
  printf '%s\n' "$((now - mtime))"
}

human_age() {
  local seconds="$1"
  if (( seconds < 60 )); then
    printf '%ss' "$seconds"
  elif (( seconds < 3600 )); then
    printf '%sm%02ss' "$((seconds / 60))" "$((seconds % 60))"
  else
    printf '%sh%02sm' "$((seconds / 3600))" "$(((seconds % 3600) / 60))"
  fi
}

manifest_value_for() {
  local manifest="$1"
  local wanted_session="$2"
  local wanted_pane="$3"
  local wanted_field="$4"
  local session pane dir title command

  [[ -f "$manifest" ]] || return 0

  while IFS=$'\t' read -r session pane dir title command || [[ -n "${session:-}" ]]; do
    [[ -n "${session:-}" && "${session:0:1}" != "#" ]] || continue
    [[ "$session" == "$wanted_session" && "$pane" == "$wanted_pane" ]] || continue
    case "$wanted_field" in
      dir)
        printf '%s\n' "$dir"
        ;;
      title)
        printf '%s\n' "$title"
        ;;
      command)
        printf '%s\n' "$command"
        ;;
    esac
    return 0
  done < "$manifest"
}

fallback_title_for_path() {
  local path="$1"
  local name

  name="${path##*/}"
  [[ -n "$name" ]] || name="shell"
  printf '%s\n' "$name"
}

apply_agent_manifest_metadata() {
  local manifest="${1:-}"
  local session pane dir title command target kind

  [[ -n "$manifest" && -f "$manifest" ]] || return 0

  while IFS=$'\t' read -r session pane dir title command || [[ -n "${session:-}" ]]; do
    [[ -n "${session:-}" && "${session:0:1}" != "#" ]] || continue
    target="$session:1.$pane"
    kind="$(agent_kind_for_command "$command")"
    "$TMUX_BIN" set-option -pt "$target" @tt_base_title "$title" 2>/dev/null || true
    "$TMUX_BIN" set-option -pt "$target" @tt_agent_command "$command" 2>/dev/null || true
    "$TMUX_BIN" set-option -pt "$target" @tt_agent_kind "$kind" 2>/dev/null || true
    set_pane_git_label "$target" "$dir"
  done < "$manifest"
}

write_agent_cockpit_state() {
  local output="${1:-}"
  local quiet="${2:-}"
  local seed tmp session profile window pane window_panes dir start_command current_command live_title base_title seed_title seed_command command kind
  local rows=0

  [[ -n "$output" ]] || output="$(agent_cockpit_state_file)"
  seed="$(agent_cockpit_manifest)"
  if [[ "$seed" == "$output" ]]; then
    seed="$(agent_cockpit_seed_manifest)"
  fi

  mkdir -p "$(dirname "$output")"
  tmp="$output.$$"
  printf '# session\tpane\tdir\ttitle\tcommand\n' > "$tmp"

  while IFS=$'\t' read -r session profile window pane window_panes dir start_command current_command live_title base_title || [[ -n "${session:-}" ]]; do
    [[ -n "${session:-}" ]] || continue
    [[ "$session" != ttm-* ]] || continue
    [[ "$profile" != "ops" ]] || continue
    [[ "$profile" != "mobile" ]] || continue
    [[ "$profile" == "studio" || "$window_panes" == "6" ]] || continue

    seed_title="$(manifest_value_for "$seed" "$session" "$pane" title)"
    seed_command="$(manifest_value_for "$seed" "$session" "$pane" command)"

    if [[ -n "$base_title" ]]; then
      title="$base_title"
    elif [[ -z "$seed_command" && "$current_command" == "zsh" && -n "$live_title" && "$live_title" != "zsh" ]]; then
      title="$live_title"
    elif [[ -n "$seed_title" ]]; then
      title="$seed_title"
    elif [[ -n "$live_title" ]]; then
      title="$live_title"
    else
      title="$(fallback_title_for_path "$dir")"
    fi

    command="$(clean_agent_command "$start_command")"
    if [[ -z "$command" && "$current_command" != "zsh" && "$current_command" != "fish" && "$current_command" != "bash" ]]; then
      command="$seed_command"
    fi
    kind="$(agent_kind_for_command "$command")"

    printf '%s\t%s\t%s\t%s\t%s\n' "$session" "$pane" "$dir" "$title" "$command" >> "$tmp"
    rows=$((rows + 1))
    "$TMUX_BIN" set-option -pt "$session:1.$pane" @tt_base_title "$title" 2>/dev/null || true
    "$TMUX_BIN" set-option -pt "$session:1.$pane" @tt_agent_command "$command" 2>/dev/null || true
    "$TMUX_BIN" set-option -pt "$session:1.$pane" @tt_agent_kind "$kind" 2>/dev/null || true
    set_pane_git_label "$session:1.$pane" "$dir"
  done < <("$TMUX_BIN" list-panes -a -F '#{session_name}	#{@tt_profile}	#{window_index}	#{pane_index}	#{window_panes}	#{pane_current_path}	#{pane_start_command}	#{pane_current_command}	#{pane_title}	#{@tt_base_title}' 2>/dev/null || true)

  if (( rows == 0 )); then
    rm -f "$tmp"
    if [[ "$quiet" != "--quiet" ]]; then
      printf 'tt snapshot skipped: no live agent cockpit panes\n' >&2
    fi
    return 0
  fi

  mv "$tmp" "$output"
  record_snapshot_history "$output" "agent-cockpit"
  if [[ "$quiet" != "--quiet" ]]; then
    printf 'tt snapshot saved: %s\n' "$output" >&2
  fi
}

write_codex_cockpit_snapshot() {
  local output="${1:-}"
  local quiet="${2:-}"

  [[ -n "$output" ]] || output="$(codex_cockpit_snapshot_file)"
  mkdir -p "$(dirname "$output")"

  TT_TMUX_BIN="$TMUX_BIN" TT_LOGIN_SHELL="$(default_login_shell)" python3 - "$output" <<'PY'
import os
import pathlib
import re
import shlex
import subprocess
import sys
import tempfile
from collections import defaultdict

output = pathlib.Path(sys.argv[1])
tmux = os.environ.get("TT_TMUX_BIN", "tmux")
login_shell = os.environ.get("TT_LOGIN_SHELL") or "/bin/zsh"
sid_re = re.compile(r"\b([0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12})\b")


def run(args):
    try:
        return subprocess.check_output(args, text=True, stderr=subprocess.DEVNULL)
    except (FileNotFoundError, subprocess.CalledProcessError):
        return ""


def clean(value):
    return (value or "").replace("\t", " ").replace("\n", " ").strip()


def descendants(root, children):
    result = []
    stack = list(children.get(root, []))
    while stack:
        pid = stack.pop(0)
        result.append(pid)
        stack.extend(children.get(pid, []))
    return result


ps_children = defaultdict(list)
ps_command = {}
for line in run(["ps", "-axo", "pid=,ppid=,command="]).splitlines():
    match = re.match(r"\s*(\d+)\s+(\d+)\s+(.*)", line)
    if not match:
        continue
    pid, ppid, command = match.groups()
    pid = int(pid)
    ppid = int(ppid)
    ps_children[ppid].append(pid)
    ps_command[pid] = command

rows = []
pane_format = "#{session_name}:#{window_index}.#{pane_index}\t#{pane_pid}\t#{pane_title}\t#{pane_current_command}\t#{pane_current_path}"
for line in run([tmux, "list-panes", "-a", "-F", pane_format]).splitlines():
    try:
        target, pane_pid, title, current_command, cwd = line.split("\t", 4)
    except ValueError:
        continue

    pane_pid_int = int(pane_pid)
    codex_commands = []
    claude_commands = []
    ids = []

    for pid in descendants(pane_pid_int, ps_children):
        command = ps_command.get(pid, "")
        if "codex" in command and "tokenjuice" not in command:
            codex_commands.append(command)
            command_ids = sid_re.findall(command)
            ids.extend(command_ids)
            if not command_ids:
                for lsof_line in run(["lsof", "-w", "-F", "n", "-p", str(pid)]).splitlines():
                    if not lsof_line.startswith("n/Users/vincentkoc/.codex/sessions/"):
                        continue
                    ids.extend(sid_re.findall(lsof_line[1:]))
        elif re.search(r"(^|/)claude(\s|$)|Claude Code", command):
            claude_commands.append(command)

    ids = list(dict.fromkeys(ids))
    kind = "shell"
    status = "shell"
    session_id = ""
    restore = f"cd {shlex.quote(cwd)} && exec {shlex.quote(login_shell)} -il"

    if codex_commands:
        kind = "codex"
        command_text = " ".join(codex_commands)
        dangerous = " --dangerously-bypass-approvals-and-sandbox" if "--dangerously-bypass-approvals-and-sandbox" in command_text else ""
        if ids:
            session_id = ids[0]
            status = "exact"
            restore = f"cd {shlex.quote(cwd)} && codex resume{dangerous} --no-alt-screen {session_id}"
        elif "resume --all" in command_text:
            status = "picker"
            restore = f"cd {shlex.quote(cwd)} && codex resume --all --no-alt-screen"
        else:
            status = "unresolved"
            restore = f"cd {shlex.quote(cwd)} && codex --no-alt-screen"
    elif claude_commands:
        kind = "claude"
        status = "resume"
        dangerous = " --dangerously-skip-permissions" if "--dangerously-skip-permissions" in " ".join(claude_commands) else ""
        restore = f"cd {shlex.quote(cwd)} && claude{dangerous} resume"

    rows.append([target, kind, cwd, title, current_command, session_id, status, restore])

output.parent.mkdir(parents=True, exist_ok=True)
fd, tmp_name = tempfile.mkstemp(prefix=output.name + ".", dir=str(output.parent))
with os.fdopen(fd, "w") as handle:
    handle.write("# target\tkind\tcwd\ttitle\tcurrent_command\tsession_id\tstatus\trestore\n")
    for row in rows:
        handle.write("\t".join(clean(value) for value in row) + "\n")
os.replace(tmp_name, output)
PY

  record_snapshot_history "$output" "codex-cockpit"
  if [[ "$quiet" != "--quiet" ]]; then
    printf 'tt codex snapshot saved: %s\n' "$output" >&2
  fi
  refresh_agent_window_state
}

show_codex_snapshot() {
  local snapshot="${1:-}"
  [[ -n "$snapshot" ]] || snapshot="$(codex_cockpit_snapshot_file)"
  if [[ ! -f "$snapshot" ]]; then
    echo "codex snapshot not found: $snapshot" >&2
    return 1
  fi
  sed -n '1,120p' "$snapshot"
}

restore_preview() {
  local snapshot="${1:-}"
  [[ -n "$snapshot" ]] || snapshot="$(codex_cockpit_snapshot_file)"
  if [[ ! -f "$snapshot" ]]; then
    echo "codex snapshot not found: $snapshot" >&2
    return 1
  fi

  awk -F '\t' '
    BEGIN {
      printf "%-16s %-7s %-10s %-28s %-38s %s\n", "target", "kind", "status", "title", "cwd", "restore"
      printf "%-16s %-7s %-10s %-28s %-38s %s\n", "------", "----", "------", "-----", "---", "-------"
    }
    $1 !~ /^#/ && ($2 == "codex" || $2 == "claude") {
      title = $4
      cwd = $3
      if (length(title) > 27) title = substr(title, 1, 24) "..."
      if (length(cwd) > 37) cwd = "..." substr(cwd, length(cwd) - 33)
      printf "%-16s %-7s %-10s %-28s %-38s %s\n", $1, $2, $7, title, cwd, $8
    }
  ' "$snapshot"
}

popup_view() {
  local view="${1:-snapshot}"
  local tmp status=0

  tmp="$(mktemp "${TMPDIR:-/tmp}/tt-popup.XXXXXX")"
  case "$view" in
    snapshot|codex-snapshot)
      show_codex_snapshot > "$tmp" 2>&1 || status=$?
      ;;
    preview|restore-preview)
      restore_preview > "$tmp" 2>&1 || status=$?
      ;;
    history|snapshot-history)
      list_snapshot_history > "$tmp" 2>&1 || status=$?
      ;;
    status)
      status_report > "$tmp" 2>&1 || status=$?
      ;;
    doctor)
      doctor_tmux --fix > "$tmp" 2>&1 || status=$?
      ;;
    *)
      printf 'usage: tt popup [snapshot|restore-preview|snapshot-history|status|doctor]\n' > "$tmp"
      status=2
      ;;
  esac

  if [[ -t 1 ]] && command -v less >/dev/null 2>&1; then
    LESS= less -SR "$tmp"
  else
    cat "$tmp"
  fi
  rm -f "$tmp"
  return "$status"
}

status_report() {
  local snapshot agent_snapshot pid_file pid timer="stopped" autosave="off"
  local snapshot_age agent_age history_count history_max
  local panes codex claude exact unresolved shell waiting spinning menu_left menu_right static_status mouse copy_modes mobile_mode

  snapshot="$(codex_cockpit_snapshot_file)"
  agent_snapshot="$(agent_cockpit_state_file)"
  pid_file="$(codex_cockpit_timer_pid_file)"
  history_max="${TT_SNAPSHOT_HISTORY_MAX:-864}"

  if [[ -f "$pid_file" ]]; then
    pid="$(cat "$pid_file" 2>/dev/null || true)"
    if [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null && ps -p "$pid" -o command= 2>/dev/null | grep -q 'codex-snapshot-loop'; then
      timer="running pid=$pid"
    fi
  fi

  if "$TMUX_BIN" show-hooks -g 2>/dev/null | grep -q 'codex-snapshot --quiet'; then
    autosave="on"
  fi

  if [[ -f "$snapshot" ]]; then
    snapshot_age="$(file_age_seconds "$snapshot" 2>/dev/null || true)"
    [[ -n "$snapshot_age" ]] && snapshot_age="$(human_age "$snapshot_age") ago" || snapshot_age="unknown"
    panes="$(awk -F '\t' '$1 !~ /^#/ {n++} END {print n+0}' "$snapshot")"
    codex="$(awk -F '\t' '$1 !~ /^#/ && $2 == "codex" {n++} END {print n+0}' "$snapshot")"
    claude="$(awk -F '\t' '$1 !~ /^#/ && $2 == "claude" {n++} END {print n+0}' "$snapshot")"
    shell="$(awk -F '\t' '$1 !~ /^#/ && $2 == "shell" {n++} END {print n+0}' "$snapshot")"
    exact="$(awk -F '\t' '$1 !~ /^#/ && $7 == "exact" {n++} END {print n+0}' "$snapshot")"
    unresolved="$(awk -F '\t' '$1 !~ /^#/ && $7 == "unresolved" {n++} END {print n+0}' "$snapshot")"
    waiting="$(awk -F '\t' '$1 !~ /^#/ && ($2 == "codex" || $2 == "claude") && $4 !~ /^[⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏⠂]/ {n++} END {print n+0}' "$snapshot")"
    spinning="$(awk -F '\t' '$1 !~ /^#/ && ($2 == "codex" || $2 == "claude") && $4 ~ /^[⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏⠂]/ {n++} END {print n+0}' "$snapshot")"
  else
    snapshot_age="missing"
    panes=0 codex=0 claude=0 shell=0 exact=0 unresolved=0 waiting=0 spinning=0
  fi

  if [[ -f "$agent_snapshot" ]]; then
    agent_age="$(file_age_seconds "$agent_snapshot" 2>/dev/null || true)"
    [[ -n "$agent_age" ]] && agent_age="$(human_age "$agent_age") ago" || agent_age="unknown"
  else
    agent_age="missing"
  fi

  history_count="$(count_snapshot_history codex-cockpit)"
  if "$TMUX_BIN" list-keys -T root MouseDown1StatusRight 2>/dev/null | grep -q 'codex-snapshot'; then
    menu_left="bound"
  else
    menu_left="missing"
  fi
  if "$TMUX_BIN" list-keys -T root MouseDown3StatusRight 2>/dev/null | grep -q 'display-menu'; then
    menu_right="bound"
  else
    menu_right="missing"
  fi
  if enforce_static_tmux_status --quiet; then
    static_status="ok"
  else
    static_status="shell-backed format found"
  fi
  mouse="$("$TMUX_BIN" show -gqv mouse 2>/dev/null || printf 'unknown')"
  copy_modes="$("$TMUX_BIN" list-panes -a -F '#{pane_in_mode}' 2>/dev/null | awk '$1 == "1" {n++} END {print n+0}')"
  mobile_mode="direct pane attach"

  printf 'autosave: %s\n' "$autosave"
  printf 'timer: %s\n' "$timer"
  printf 'snapshot: %s (%s)\n' "$snapshot" "$snapshot_age"
  printf 'agent snapshot: %s (%s)\n' "$agent_snapshot" "$agent_age"
  printf 'history: %s/%s codex-cockpit files\n' "$history_count" "$history_max"
  printf 'agents: %s panes, %s codex, %s claude, %s shell\n' "$panes" "$codex" "$claude" "$shell"
  printf 'restore: %s exact, %s unresolved\n' "$exact" "$unresolved"
  printf 'work state: %s waiting, %s spinning\n' "$waiting" "$spinning"
  printf 'menu: left=%s right=%s\n' "$menu_left" "$menu_right"
  printf 'status: %s\n' "$static_status"
  printf 'mouse: %s, copy-mode panes: %s\n' "$mouse" "$copy_modes"
  printf 'mobile: %s\n' "$mobile_mode"
}

doctor_tmux() {
  local mode="${1:---fix}"

  case "$mode" in
    --check|check)
      status_report
      return
      ;;
    --fix|fix|'')
      ;;
    *)
      echo "usage: tt doctor [--fix|--check]" >&2
      return 2
      ;;
  esac

  printf 'repair: mouse on\n'
  "$TMUX_BIN" set -g mouse on

  printf 'repair: clear legacy shell status widgets\n'
  clear_legacy_shell_status_widgets

  printf 'repair: restore static tab/status formats\n'
  set_agent_window_status_formats

  printf 'repair: install CX SAVE menu\n'
  install_agent_status_menu

  printf 'repair: sync pane notes\n'
  sync_pane_notes all

  printf 'repair: sync pane markers\n'
  sync_pane_markers all

  clear_stale_agent_attention_pane_styles

  sync_mosh_attention_panes --quiet

  printf 'repair: install autosave hooks/timer\n'
  install_agent_autosave_hooks

  printf 'repair: refresh snapshots\n'
  write_agent_cockpit_state "$(agent_cockpit_state_file)" --quiet
  write_codex_cockpit_snapshot "$(codex_cockpit_snapshot_file)" --quiet

  printf '\n'
  status_report
}

codex_restore_matches() {
  local mode="${1:-preview}"
  local selector="${2:-}"
  local snapshot="${3:-}"

  [[ -n "$snapshot" ]] || snapshot="$(codex_cockpit_snapshot_file)"
  [[ -f "$snapshot" ]] || { echo "codex snapshot not found: $snapshot" >&2; return 1; }

  awk -F '\t' -v mode="$mode" -v selector="$selector" '
    $1 ~ /^#/ || !($2 == "codex" || $2 == "claude") { next }
    mode == "all" { print; next }
    mode == "pane" && $1 == selector { print; next }
    mode == "window" && index($1, selector ".") == 1 { print; next }
    mode == "session" && index($1, selector ":") == 1 { print; next }
  ' "$snapshot"
}

codex_restore_execute() {
  local mode="${1:-preview}"
  local selector="${2:-}"
  local snapshot="${3:-}"
  local execute="${4:-}"
  local target kind cwd title current_command session_id status restore
  local matched=0 restored=0 missing=0

  if [[ "$selector" == "--execute" ]]; then
    execute="--execute"
    selector=""
  fi
  if [[ "$snapshot" == "--execute" ]]; then
    execute="--execute"
    snapshot=""
  fi
  if [[ "$mode" == "all" && -n "$selector" && -z "$snapshot" ]]; then
    snapshot="$selector"
    selector=""
  fi

  case "$mode" in
    preview)
      restore_preview "$selector"
      return
      ;;
    all)
      ;;
    pane|window|session)
      [[ -n "$selector" ]] || { echo "usage: tt codex-restore $mode <target>" >&2; return 2; }
      ;;
    *)
      echo "usage: tt codex-restore [preview|all|pane <target>|window <session:window>|session <session>] [snapshot] [--execute]" >&2
      return 2
      ;;
  esac

  if [[ "$execute" != "--execute" ]]; then
    echo "dry run; add --execute to respawn matching panes" >&2
    while IFS=$'\t' read -r target kind cwd title current_command session_id status restore || [[ -n "${target:-}" ]]; do
      [[ -n "${target:-}" ]] || continue
      matched=$((matched + 1))
      printf '%s\t%s\t%s\t%s\n' "$target" "$kind" "$status" "$restore"
    done < <(codex_restore_matches "$mode" "$selector" "$snapshot")
    if (( matched == 0 )); then
      echo "no matching Codex/Claude panes" >&2
      return 1
    fi
    return 0
  fi

  while IFS=$'\t' read -r target kind cwd title current_command session_id status restore || [[ -n "${target:-}" ]]; do
    [[ -n "${target:-}" ]] || continue
    matched=$((matched + 1))
    printf '%s\t%s\t%s\t%s\n' "$target" "$kind" "$status" "$restore"
    if "$TMUX_BIN" list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null | grep -Fxq "$target"; then
      "$TMUX_BIN" respawn-pane -k -t "$target" "$restore"
      restored=$((restored + 1))
    else
      printf 'missing pane: %s\n' "$target" >&2
      missing=$((missing + 1))
    fi
  done < <(codex_restore_matches "$mode" "$selector" "$snapshot")

  if (( matched == 0 )); then
    echo "no matching Codex/Claude panes" >&2
    return 1
  fi
  printf 'tt restored %s pane(s), missing %s\n' "$restored" "$missing" >&2
}

refresh_agent_window_state() {
  local snapshot tmp window state

  snapshot="$(codex_cockpit_snapshot_file)"
  tmp="$(mktemp "${TMPDIR:-/tmp}/tt-window-state.XXXXXX")"
  if [[ -f "$snapshot" ]]; then
    "$TMUX_BIN" list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}	#{window_id}' 2>/dev/null |
      awk -F '\t' -v snapshot="$snapshot" '
        FNR == NR {
          if ($1 !~ /^#/ && ($2 == "codex" || $2 == "claude") && $4 !~ /^[⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏⠂]/) ready[$1] = 1
          next
        }
        {
          windows[$2] = 1
          if (ready[$1]) state[$2] = "attention"
        }
        END {
          for (window in windows) {
            print window "\t" (state[window] ? state[window] : "shell")
          }
        }' "$snapshot" - > "$tmp"
  else
    "$TMUX_BIN" list-panes -a -F '#{window_id}	#{pane_title}	#{@tt_agent_kind}' 2>/dev/null |
      awk -F '\t' '
      {
        window = $1
        title = $2
        kind = $3
        windows[window] = 1
        if (kind == "CODEX" || kind == "CLAUDE") {
          if (title !~ /^[⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏⠂]/) state[window] = "attention"
        }
      }
      END {
        for (window in windows) {
          print window "\t" (state[window] ? state[window] : "shell")
        }
      }' > "$tmp"
  fi

  while IFS=$'\t' read -r window state || [[ -n "${window:-}" ]]; do
    [[ -n "${window:-}" && -n "${state:-}" ]] || continue
    "$TMUX_BIN" set-window-option -t "$window" -q @tt_window_agent_state "$state" 2>/dev/null || true
  done < "$tmp"
  rm -f "$tmp"
}

codex_snapshot_timer_loop() {
  local interval="${TT_CODEX_SNAPSHOT_INTERVAL:-300}"

  case "$interval" in
    ''|*[!0-9]*)
      interval=300
      ;;
  esac
  if (( interval < 30 )); then
    interval=30
  fi

  while true; do
    write_codex_cockpit_snapshot "$(codex_cockpit_snapshot_file)" --quiet || true
    sleep "$interval"
  done
}

tt_self_command() {
  if [[ -x "$HOME/bin/tt" ]]; then
    shell_quote "$HOME/bin/tt"
  else
    shell_quote "$SCRIPT_DIR/tt"
  fi
}

enforce_static_tmux_status() {
  local quiet="${1:-}"
  local opt value failed=0
  for opt in status-left status-right window-status-format window-status-current-format; do
    value="$("$TMUX_BIN" show -gqv "$opt" 2>/dev/null || true)"
    if [[ "$value" == *'#('* ]]; then
      failed=1
      [[ "$quiet" == "--quiet" ]] || printf 'shell-backed status format found in %s\n' "$opt" >&2
    fi
  done
  return "$failed"
}

clear_legacy_shell_status_widgets() {
  "$TMUX_BIN" set -gu @agent_attention_segment 2>/dev/null || true
  "$TMUX_BIN" set -gu @agent_attention_state 2>/dev/null || true
  "$TMUX_BIN" set -gu @hn_ticker 2>/dev/null || true
  "$TMUX_BIN" set -gu @hn_ticker_cache 2>/dev/null || true
  "$TMUX_BIN" set -gu @hn_ticker_last 2>/dev/null || true
}

is_agent_attention_pane_style() {
  local style="${1:-}" active_style="${2:-}"

  case "$style|$active_style" in
    "fg=default,bg=#241d12|fg=default,bg=#2f2517") return 0 ;;
    "fg=default,bg=#2b1720|fg=default,bg=#361b27") return 0 ;;
    *) return 1 ;;
  esac
}

clear_stale_agent_attention_pane_styles() {
  local target marker style active_style cleared=0

  while IFS= read -r target; do
    [[ -n "$target" ]] || continue
    marker="$("$TMUX_BIN" show-options -pt "$target" -qv @tt_marker 2>/dev/null || true)"
    [[ -z "$marker" ]] || continue

    style="$("$TMUX_BIN" show-options -pt "$target" -qv window-style 2>/dev/null || true)"
    active_style="$("$TMUX_BIN" show-options -pt "$target" -qv window-active-style 2>/dev/null || true)"
    if is_agent_attention_pane_style "$style" "$active_style"; then
      "$TMUX_BIN" set-option -pt "$target" -qu window-style 2>/dev/null || true
      "$TMUX_BIN" set-option -pt "$target" -qu window-active-style 2>/dev/null || true
      "$TMUX_BIN" set-option -pt "$target" -qu @agent_pane_badge 2>/dev/null || true
      cleared=$((cleared + 1))
    fi
  done < <("$TMUX_BIN" list-panes -a -F '#{pane_id}' 2>/dev/null || true)

  printf 'repair: cleared %s stale agent attention pane style(s)\n' "$cleared"
}

reset_agent_attention_pane() {
  local target="${1:-${TMUX_PANE:-}}"
  local marker style active_style badge tty

  [[ -n "$target" ]] || return 0

  marker="$("$TMUX_BIN" show-options -pt "$target" -qv @tt_marker 2>/dev/null || true)"
  style="$("$TMUX_BIN" show-options -pt "$target" -qv window-style 2>/dev/null || true)"
  active_style="$("$TMUX_BIN" show-options -pt "$target" -qv window-active-style 2>/dev/null || true)"
  badge="$("$TMUX_BIN" show-options -pt "$target" -qv @agent_pane_badge 2>/dev/null || true)"

  if [[ -n "$marker" ]]; then
    return 0
  fi
  if [[ -z "$badge" ]] && ! is_agent_attention_pane_style "$style" "$active_style"; then
    return 0
  fi

  "$TMUX_BIN" set-option -pt "$target" -qu @agent_pane_badge 2>/dev/null || true
  "$TMUX_BIN" set-option -pt "$target" -qu window-style 2>/dev/null || true
  "$TMUX_BIN" set-option -pt "$target" -qu window-active-style 2>/dev/null || true

  tty="$("$TMUX_BIN" display-message -p -t "$target" '#{pane_tty}' 2>/dev/null || true)"
  if [[ -n "$tty" && -w "$tty" ]]; then
    printf '\033]11;#1a1b26\007\033]12;#c0caf5\007' >"$tty" 2>/dev/null || true
  fi
}

mosh_target_for_pane() {
  local target="$1"
  local pane_pid child command remote

  pane_pid="$("$TMUX_BIN" display-message -p -t "$target" '#{pane_pid}' 2>/dev/null || true)"
  [[ -n "$pane_pid" ]] || return 1

  while IFS= read -r child; do
    command="$(ps -ww -o command= -p "$child" 2>/dev/null || true)"
    [[ "$command" == *mosh-client* && "$command" == *" -- "* ]] || continue
    remote="${command##* -- }"
    remote="${remote%% | *}"
    remote="${remote%% *}"
    [[ -n "$remote" ]] || continue
    printf '%s\n' "$remote"
    return 0
  done < <(pgrep -P "$pane_pid" 2>/dev/null || true)

  return 1
}

remote_agent_attention_state() {
  local remote="$1"

  ssh -o BatchMode=yes -o ConnectTimeout=3 -o ServerAliveInterval=15 -o ServerAliveCountMax=1 "$remote" '
    if ! command -v tmux >/dev/null 2>&1 || ! tmux ls >/dev/null 2>&1; then
      printf "reset\n"
      exit 0
    fi
    state=reset
    for pane in $(tmux list-panes -a -F "#{pane_id}" 2>/dev/null); do
      badge="$(tmux show-options -pt "$pane" -qv @agent_pane_badge 2>/dev/null || true)"
      case "$badge" in
        *APPROVE*) printf "approve\n"; exit 0 ;;
        *WAIT*) state=waiting ;;
      esac
    done
    printf "%s\n" "$state"
  ' 2>/dev/null | sed -n '1p'
}

apply_mosh_attention_state() {
  local target="$1" state="$2"
  local marker style active_style

  marker="$("$TMUX_BIN" show-options -pt "$target" -qv @tt_marker 2>/dev/null || true)"
  [[ -z "$marker" ]] || return 0

  case "$state" in
    approve)
      "$TMUX_BIN" set-option -pt "$target" window-style "fg=default,bg=#2b1720" 2>/dev/null || true
      "$TMUX_BIN" set-option -pt "$target" window-active-style "fg=default,bg=#361b27" 2>/dev/null || true
      "$TMUX_BIN" set-option -pt "$target" -qu @agent_pane_badge 2>/dev/null || true
      ;;
    waiting)
      "$TMUX_BIN" set-option -pt "$target" window-style "fg=default,bg=#241d12" 2>/dev/null || true
      "$TMUX_BIN" set-option -pt "$target" window-active-style "fg=default,bg=#2f2517" 2>/dev/null || true
      "$TMUX_BIN" set-option -pt "$target" -qu @agent_pane_badge 2>/dev/null || true
      ;;
    reset|active|idle|clear|'')
      style="$("$TMUX_BIN" show-options -pt "$target" -qv window-style 2>/dev/null || true)"
      active_style="$("$TMUX_BIN" show-options -pt "$target" -qv window-active-style 2>/dev/null || true)"
      if is_agent_attention_pane_style "$style" "$active_style"; then
        "$TMUX_BIN" set-option -pt "$target" -qu window-style 2>/dev/null || true
        "$TMUX_BIN" set-option -pt "$target" -qu window-active-style 2>/dev/null || true
      fi
      "$TMUX_BIN" set-option -pt "$target" -qu @agent_pane_badge 2>/dev/null || true
      ;;
  esac
}

sync_mosh_attention_panes() {
  local quiet="${1:-}"
  local target command remote state count=0

  while IFS=$'\t' read -r target command; do
    [[ "$command" == "mosh-client" ]] || continue
    remote="$(mosh_target_for_pane "$target")" || continue
    state="$(remote_agent_attention_state "$remote")"
    [[ -n "$state" ]] || continue
    apply_mosh_attention_state "$target" "$state"
    count=$((count + 1))
    [[ "$quiet" == "--quiet" ]] || printf 'mosh-attn: %s -> %s (%s)\n' "$target" "$remote" "$state"
  done < <("$TMUX_BIN" list-panes -a -F '#{pane_id}	#{pane_current_command}' 2>/dev/null || true)

  [[ "$quiet" == "--quiet" ]] || printf 'mosh-attn: synced %s pane(s)\n' "$count"
}

show_pane_menu() {
  local target="${1:-${TMUX_PANE:-}}"
  local x="${2:-P}"
  local y="${3:-P}"
  local client="${4:-}"
  local self tmux_cmd
  local -a client_args=()

  [[ -n "$target" ]] || return 0
  self="$(tt_self_command)"
  tmux_cmd="$(shell_quote "$TMUX_BIN")"
  [[ -n "$client" ]] && client_args=(-c "$client")

  "$TMUX_BIN" display-menu "${client_args[@]}" -T "Pane #{pane_index}" -t "$target" -x "$x" -y "$y" \
    "Edit note" e "display-popup -t '#{pane_id}' -T 'note: #{session_name}:#{window_index}.#{pane_index}' -x '#{pane_left}' -y '#{pane_top}' -w 84 -h 24 -E '$self note edit #{pane_id}'" \
    "Show note" v "display-popup -t '#{pane_id}' -T 'note: #{session_name}:#{window_index}.#{pane_index}' -x '#{pane_left}' -y '#{pane_top}' -w 72 -h 16 -E '$self note show #{pane_id} | LESS= less -SR'" \
    "Replace with quick note" n "display-popup -t '#{pane_id}' -T 'quick note: #{session_name}:#{window_index}.#{pane_index}' -x '#{pane_left}' -y '#{pane_top}' -w 64 -h 10 -E '$self note prompt #{pane_id}'" \
    "Clear note" c "run-shell -b '$self note clear #{pane_id} && $tmux_cmd display-message \"pane note cleared\"'" \
    "" "" "" \
    "Marker default" 0 "run-shell -b '$self marker set #{pane_id} default && $tmux_cmd display-message \"pane marker default\"'" \
    "Marker amber" 1 "run-shell -b '$self marker set #{pane_id} amber && $tmux_cmd display-message \"pane marker amber\"'" \
    "Marker green" 2 "run-shell -b '$self marker set #{pane_id} green && $tmux_cmd display-message \"pane marker green\"'" \
    "Marker blue" 3 "run-shell -b '$self marker set #{pane_id} blue && $tmux_cmd display-message \"pane marker blue\"'" \
    "Dim pane" 4 "run-shell -b '$self marker set #{pane_id} dim && $tmux_cmd display-message \"pane dimmed\"'" \
    "" "" "" \
    "Sync pane" s "run-shell -b '$self note sync #{pane_id} && $tmux_cmd display-message \"pane note synced\"'" \
    "Sync all notes" a "run-shell -b '$self note sync all && $tmux_cmd display-message \"pane notes synced\"'" \
    "" "" "" \
    "Split horizontal" h "split-window -h -c '#{pane_current_path}'" \
    "Split vertical" V "split-window -v -c '#{pane_current_path}'" \
    "#{?#{>:#{window_panes},1},,-}Swap Up" u "swap-pane -U" \
    "#{?#{>:#{window_panes},1},,-}Swap Down" d "swap-pane -D" \
    "#{?pane_marked_set,,-}Swap Marked" S "swap-pane" \
    "#{?pane_marked,Unmark,Mark}" m "select-pane -m" \
    "#{?window_zoomed_flag,Unzoom,Zoom}" z "resize-pane -Z" \
    "Respawn" R "respawn-pane -k" \
    "Kill" X "kill-pane" 2>/dev/null || true
}

install_agent_status_menu() {
  local self tmux_cmd mouse_passthrough_expr
  self="$(tt_self_command)"
  tmux_cmd="$(shell_quote "$TMUX_BIN")"
  mouse_passthrough_expr='#{||:#{==:#{pane_current_command},mosh-client},#{==:#{pane_current_command},ssh}}'

  "$TMUX_BIN" bind-key N display-popup -t "#{pane_id}" -T "note: #{session_name}:#{window_index}.#{pane_index}" -x "#{pane_left}" -y "#{pane_top}" -w 84 -h 24 -E "$self note edit #{pane_id}" 2>/dev/null || true
  "$TMUX_BIN" bind-key -T root MouseDown3Pane if-shell -F "$mouse_passthrough_expr" "select-pane -t = \\; send-keys -M" "run-shell -b '$self pane-menu #{pane_id} #{mouse_x} #{mouse_y} #{client_name}'" 2>/dev/null || true

  "$TMUX_BIN" bind-key -T root MouseDown1StatusRight run-shell -b "$self codex-snapshot --quiet && $tmux_cmd display-message 'codex snapshot saved'" 2>/dev/null || true
  "$TMUX_BIN" bind-key -T root MouseDown3StatusRight display-menu -T "CX SAVE" -x M -y W \
    "Save now" s "run-shell -b '$self codex-snapshot --quiet && $tmux_cmd display-message \"codex snapshot saved\"'" \
    "Show snapshot" v "display-popup -w 95% -h 80% -E '$self popup snapshot'" \
    "Restore preview" p "display-popup -w 95% -h 80% -E '$self popup restore-preview'" \
    "Snapshot history" h "display-popup -w 95% -h 80% -E '$self popup snapshot-history'" \
    "Status" t "display-popup -w 95% -h 80% -E '$self popup status'" \
    "Doctor" d "display-popup -w 95% -h 80% -E '$self popup doctor'" \
    "Mobile pane picker" m "display-popup -w 95% -h 80% -E '$self mobile'" \
    "" "" "" \
    "Autosave on" o "run-shell -b '$self autosave on && $tmux_cmd display-message \"codex autosave on\"'" \
    "Autosave off" f "run-shell -b '$self autosave off && $tmux_cmd display-message \"codex autosave off\"'" 2>/dev/null || true

  "$TMUX_BIN" set-hook -g "after-select-pane[92]" "run-shell -b '$self attention-reset #{pane_id}'" 2>/dev/null || true
  "$TMUX_BIN" set-hook -g "after-select-window[92]" "run-shell -b '$self attention-reset #{pane_id}'" 2>/dev/null || true
}

install_agent_autosave_hooks() {
  local self
  self="$(tt_self_command)"

  "$TMUX_BIN" set-hook -g "after-new-session[90]" "run-shell -b '$self snapshot --quiet'" 2>/dev/null || true
  "$TMUX_BIN" set-hook -g "after-new-window[90]" "run-shell -b '$self snapshot --quiet'" 2>/dev/null || true
  "$TMUX_BIN" set-hook -g "after-split-window[90]" "run-shell -b '$self snapshot --quiet'" 2>/dev/null || true
  "$TMUX_BIN" set-hook -g "after-kill-pane[90]" "run-shell -b '$self snapshot --quiet'" 2>/dev/null || true
  "$TMUX_BIN" set-hook -g "pane-exited[90]" "run-shell -b '$self snapshot --quiet'" 2>/dev/null || true
  "$TMUX_BIN" set-hook -g "after-new-session[91]" "run-shell -b '$self codex-snapshot --quiet'" 2>/dev/null || true
  "$TMUX_BIN" set-hook -g "after-new-window[91]" "run-shell -b '$self codex-snapshot --quiet'" 2>/dev/null || true
  "$TMUX_BIN" set-hook -g "after-split-window[91]" "run-shell -b '$self codex-snapshot --quiet'" 2>/dev/null || true
  "$TMUX_BIN" set-hook -g "after-kill-pane[91]" "run-shell -b '$self codex-snapshot --quiet'" 2>/dev/null || true
  "$TMUX_BIN" set-hook -g "pane-exited[91]" "run-shell -b '$self codex-snapshot --quiet'" 2>/dev/null || true
  install_agent_status_menu
  clear_legacy_shell_status_widgets
  set_agent_window_status_formats
  sync_pane_markers all
  refresh_agent_window_state
  enforce_static_tmux_status --quiet || true
  start_codex_snapshot_timer
}

clear_agent_autosave_hooks() {
  "$TMUX_BIN" set-hook -gu "after-new-session[90]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "after-new-window[90]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "after-split-window[90]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "after-kill-pane[90]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "pane-exited[90]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "after-new-session[91]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "after-new-window[91]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "after-split-window[91]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "after-kill-pane[91]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "pane-exited[91]" 2>/dev/null || true
  install_agent_status_menu

  # Remove the unindexed hooks from early versions of this script if they are still present.
  "$TMUX_BIN" set-hook -gu "after-new-session[0]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "after-new-window[0]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "after-split-window[0]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "after-kill-pane[0]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "pane-exited[0]" 2>/dev/null || true
  "$TMUX_BIN" set-hook -gu "window-layout-changed[0]" 2>/dev/null || true
  stop_codex_snapshot_timer
}

start_codex_snapshot_timer() {
  local pid_file pid self

  pid_file="$(codex_cockpit_timer_pid_file)"
  mkdir -p "$(dirname "$pid_file")"
  if [[ -f "$pid_file" ]]; then
    pid="$(cat "$pid_file" 2>/dev/null || true)"
    if [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null; then
      if ps -p "$pid" -o command= 2>/dev/null | grep -q 'codex-snapshot-loop'; then
        return 0
      fi
    fi
  fi

  self="$(tt_self_command)"
  nohup bash -lc "exec $self codex-snapshot-loop" >/dev/null 2>&1 &
  printf '%s\n' "$!" > "$pid_file"
}

stop_codex_snapshot_timer() {
  local pid_file pid

  pid_file="$(codex_cockpit_timer_pid_file)"
  [[ -f "$pid_file" ]] || return 0
  pid="$(cat "$pid_file" 2>/dev/null || true)"
  if [[ "$pid" =~ ^[0-9]+$ ]] && kill -0 "$pid" 2>/dev/null; then
    if ps -p "$pid" -o command= 2>/dev/null | grep -q 'codex-snapshot-loop'; then
      kill "$pid" 2>/dev/null || true
    fi
  fi
  rm -f "$pid_file"
}

start_recovery_server() {
  kill_server force
  "$TMUX_BIN" -f /dev/null new-session -d -s __tt_recover -n main -c "$HOME"
  apply_recovery_theme
  install_agent_autosave_hooks
}

create_agent_cockpit_sessions() {
  local manifest="$1"
  local session pane dir title command
  local sessions=" "

  while IFS=$'\t' read -r session pane dir title command || [[ -n "${session:-}" ]]; do
    [[ -n "${session:-}" && "${session:0:1}" != "#" ]] || continue
    if [[ "$sessions" != *" $session "* ]]; then
      create_studio_detached "$session" "$dir"
      sessions="$sessions$session "
    fi
  done < "$manifest"
}

launch_agent_cockpit_panes() {
  local manifest="$1"
  local session pane dir title command target kind

  while IFS=$'\t' read -r session pane dir title command || [[ -n "${session:-}" ]]; do
    [[ -n "${session:-}" && "${session:0:1}" != "#" ]] || continue
    target="$session:1.$pane"
    kind="$(agent_kind_for_command "$command")"
    "$TMUX_BIN" set-option -pt "$target" @tt_base_title "$title" 2>/dev/null || true
    "$TMUX_BIN" set-option -pt "$target" @tt_agent_command "$command" 2>/dev/null || true
    "$TMUX_BIN" set-option -pt "$target" @tt_agent_kind "$kind" 2>/dev/null || true
    set_pane_git_label "$target" "$dir"
    "$TMUX_BIN" select-pane -t "$target" -T "$title" 2>/dev/null || true

    if [[ -n "${command:-}" ]]; then
      "$TMUX_BIN" respawn-pane -k -t "$target" -c "$dir" "$(agent_color_prefix) $command"
    else
      "$TMUX_BIN" respawn-pane -k -t "$target" -c "$dir" "$(default_login_shell_command)"
    fi
  done < "$manifest"
}

refresh_agent_pane_colors() {
  local session pane dir start_command base_title saved_command command kind count
  count=0

  while IFS=$'\t' read -r session pane dir start_command base_title saved_command || [[ -n "${session:-}" ]]; do
    [[ -n "${session:-}" ]] || continue
    [[ "$session" != ttm-* ]] || continue

    command="$(clean_agent_command "$start_command")"
    if [[ -z "$command" ]]; then
      command="$(clean_agent_command "$saved_command")"
    fi
    kind="$(agent_kind_for_command "$command")"
    case "$kind" in
      CODEX|CLAUDE)
        ;;
      *)
        continue
        ;;
    esac

    "$TMUX_BIN" set-option -pt "$pane" @tt_agent_command "$command" 2>/dev/null || true
    "$TMUX_BIN" set-option -pt "$pane" @tt_agent_kind "$kind" 2>/dev/null || true
    if [[ -n "$base_title" ]]; then
      "$TMUX_BIN" set-option -pt "$pane" @tt_base_title "$base_title" 2>/dev/null || true
      "$TMUX_BIN" select-pane -t "$pane" -T "$base_title" 2>/dev/null || true
    fi
    set_pane_git_label "$pane" "$dir"

    "$TMUX_BIN" respawn-pane -k -t "$pane" -c "$dir" "$(agent_color_prefix) $command"
    count=$((count + 1))
  done < <("$TMUX_BIN" list-panes -a -F '#{session_name}	#{pane_id}	#{pane_current_path}	#{pane_start_command}	#{@tt_base_title}	#{@tt_agent_command}' 2>/dev/null || true)

  write_agent_cockpit_state "$(agent_cockpit_state_file)" --quiet
  restore_studio_layout
  printf 'tt refreshed %s agent panes\n' "$count" >&2
}

recover_agent_cockpit() {
  local manifest="${1:-}"
  local attach_session="${2:-factory2}"

  if [[ -n "${TMUX:-}" ]]; then
    echo "tt recover must be run outside tmux; it rebuilds the tmux server" >&2
    exit 2
  fi

  if [[ -z "$manifest" || "$manifest" == "--default" ]]; then
    manifest="$(agent_cockpit_manifest)"
  fi
  [[ -f "$manifest" ]] || { echo "agent cockpit manifest not found: $manifest" >&2; exit 2; }
  manifest_has_entries "$manifest" || { echo "agent cockpit manifest has no sessions: $manifest" >&2; exit 2; }

  start_recovery_server
  create_agent_cockpit_sessions "$manifest"
  "$TMUX_BIN" kill-session -t __tt_recover 2>/dev/null || true
  launch_agent_cockpit_panes "$manifest"
  restore_studio_layout
  write_agent_cockpit_state "$(agent_cockpit_state_file)" --quiet

  if [[ -n "${TMUX:-}" ]]; then
    exec "$TMUX_BIN" switch-client -t "$attach_session"
  fi

  exec "$TMUX_BIN" attach -t "$attach_session"
}

snapshot_has_session() {
  local snapshot="$1"
  local session="${2:-cockpit}"

  [[ -f "$snapshot" ]] || return 1
  awk -F '\t' -v prefix="$session:" '$1 !~ /^#/ && index($1, prefix) == 1 { found=1 } END { exit found ? 0 : 1 }' "$snapshot"
}

snapshot_has_recoverable_session() {
  local snapshot="$1"
  local session="${2:-cockpit}"

  [[ -f "$snapshot" ]] || return 1
  awk -F '\t' -v prefix="$session:" '$1 !~ /^#/ && index($1, prefix) == 1 && $2 == "codex" && $7 == "exact" { found=1 } END { exit found ? 0 : 1 }' "$snapshot"
}

latest_cockpit_snapshot() {
  local requested="${1:-}"
  local session="${2:-cockpit}"
  local snapshot history_dir

  if [[ -n "$requested" && "$requested" != "--default" ]]; then
    [[ -f "$requested" ]] || { echo "codex snapshot not found: $requested" >&2; return 1; }
    snapshot_has_recoverable_session "$requested" "$session" || { echo "codex snapshot has no recoverable $session sessions: $requested" >&2; return 1; }
    printf '%s\n' "$requested"
    return 0
  fi

  snapshot="$(codex_cockpit_snapshot_file)"
  if snapshot_has_recoverable_session "$snapshot" "$session"; then
    printf '%s\n' "$snapshot"
    return 0
  fi

  history_dir="$(snapshot_history_dir codex-cockpit)"
  while IFS= read -r snapshot; do
    [[ -n "$snapshot" ]] || continue
    if snapshot_has_recoverable_session "$snapshot" "$session"; then
      printf '%s\n' "$snapshot"
      return 0
    fi
  done < <(find "$history_dir" -maxdepth 1 -type f -name '*.tsv' -print 2>/dev/null | sort -r)

  echo "no CX snapshot found for $session" >&2
  return 1
}

restore_cockpit_snapshot() {
  local snapshot="$1"
  local session="${2:-cockpit}"
  local target kind cwd title current_command session_id row_status restore shell_command restored=0

  while IFS=$'\t' read -r target kind cwd title current_command session_id row_status restore || [[ -n "${target:-}" ]]; do
    [[ -n "${target:-}" && "${target:0:1}" != "#" ]] || continue
    [[ "$target" == "$session:"* ]] || continue

    shell_command="cd $(shell_quote "$cwd") && exec $(default_login_shell_command)"
    "$TMUX_BIN" select-pane -t "$target" -T "$title" 2>/dev/null || true
    "$TMUX_BIN" respawn-pane -k -t "$target" "$shell_command" 2>/dev/null || true
  done < "$snapshot"

  while IFS=$'\t' read -r target kind cwd title current_command session_id row_status restore || [[ -n "${target:-}" ]]; do
    [[ -n "${target:-}" && "${target:0:1}" != "#" ]] || continue
    [[ "$target" == "$session:"* ]] || continue
    [[ "$kind" == "codex" && "$row_status" == "exact" && -n "$restore" ]] || continue

    "$TMUX_BIN" respawn-pane -k -t "$target" -c "$cwd" "$(agent_color_prefix) codex resume --no-alt-screen $session_id" 2>/dev/null || true
    restored=$((restored + 1))
  done < "$snapshot"

  restore_studio_layout "$session"
  apply_studio_pane_titles "$session"
  printf 'tt restored %s exact Codex pane(s)\n' "$restored" >&2
}

recover_cockpit() {
  local snapshot="${1:-}"
  local session="${2:-cockpit}"

  if [[ -n "${TMUX:-}" ]]; then
    echo "tt recover must be run outside tmux; it rebuilds the tmux server" >&2
    exit 2
  fi

  snapshot="$(latest_cockpit_snapshot "$snapshot" "$session")" || exit 2
  printf 'tt recovering %s from %s\n' "$session" "$snapshot" >&2

  start_recovery_server
  create_ops_detached "$session" "$HOME" --no-shell-upgrade
  "$TMUX_BIN" kill-session -t __tt_recover 2>/dev/null || true
  restore_cockpit_snapshot "$snapshot" "$session"

  exec "$TMUX_BIN" attach -t "$session"
}

reset_to_profile() {
  local profile="$1"
  local session="${2:-}"

  kill_server force

  case "$profile" in
    ai|studio)
      create_studio "${session:-studio}"
      ;;
    shell|plain)
      create_plain "${session:-main}"
      ;;
    mobile|phone)
      create_mobile "${session:-mobile}"
      ;;
    *)
      echo "unknown reset profile: $profile" >&2
      exit 2
      ;;
  esac
}

list_sessions() {
  "$TMUX_BIN" list-sessions -F '#S' 2>/dev/null || true
}

session_summary() {
  local session="$1"
  local pane_count profile window_count
  profile="$("$TMUX_BIN" show-options -t "$session" -qv @tt_profile 2>/dev/null || true)"
  if [[ -n "$profile" ]]; then
    printf '%s' "$profile"
    return 0
  fi

  pane_count="$("$TMUX_BIN" list-panes -t "$session" 2>/dev/null | wc -l | tr -d ' ')"
  window_count="$("$TMUX_BIN" list-windows -t "$session" 2>/dev/null | wc -l | tr -d ' ')"

  if [[ "$pane_count" == "6" && "$window_count" == "1" ]]; then
    printf 'studio'
  else
    printf 'plain'
  fi
}

profile_label() {
  case "$1" in
    studio)
      printf 'ai'
      ;;
    plain)
      printf 'shell'
      ;;
    mobile)
      printf 'mobile'
      ;;
    *)
      printf '%s' "$1"
      ;;
  esac
}

choose_with_fzf() {
  command -v fzf >/dev/null 2>&1 || return 1
  printf '%s\n' "$@" | fzf --prompt='tt > ' --height=40% --layout=reverse --border
}

choose_with_select() {
  local options=("$@")
  local choice
  PS3="tt> "

  select choice in "${options[@]}"; do
    [[ -n "${choice:-}" ]] || continue
    printf '%s\n' "$choice"
    return 0
  done
}

choose_option() {
  local options=("$@")
  local selected

  if selected="$(choose_with_fzf "${options[@]}")"; then
    printf '%s\n' "$selected"
    return 0
  fi

  choose_with_select "${options[@]}"
}

prompt_session_name() {
  local prompt="${1:-session name}"
  local default_name="${2:-}"
  local value

  if [[ -n "$default_name" ]]; then
    printf '%s [%s]: ' "$prompt" "$default_name" >&2
    read -r value
    [[ "$value" == "--" ]] && value=""
    printf '%s\n' "${value:-$default_name}"
  else
    printf '%s: ' "$prompt" >&2
    read -r value
    printf '%s\n' "$value"
  fi
}

run_menu() {
  local session selection summary
  local -a options=()

  while IFS= read -r session; do
    [[ -n "$session" ]] || continue
    summary="$(session_summary "$session")"
    options+=("attach  [$(profile_label "$summary")]  $session")
  done < <(list_sessions)

  options+=("new     [ai]     agent cockpit (3x2)")
  options+=("new     [cockpit] ops/L1/L2/L3 cockpit")
  options+=("new     [shell]  normal tmux session")
  options+=("new     [mobile] phone-sized tmux session")
  options+=("reset   [ai]     kill server + fresh agent cockpit")
  options+=("reset   [shell]  kill server + fresh shell session")
  options+=("reset   [mobile] kill server + fresh phone session")
  options+=("restore [layout] unzoom windows + retile 6-pane sessions")
  options+=("restore [preview] Codex/Claude restore map")
  options+=("recover [cockpit] rebuild CX-saved cockpit")
  options+=("recover [agents] rebuild saved agent cockpit")
  options+=("snapshot [agents] save live agent cockpit")
  options+=("snapshot [codex]  save Codex/Claude restore map")
  options+=("snapshot [history] list capped snapshots")
  options+=("autosave [on]    keep agent snapshot warm")
  options+=("autosave [off]   disable agent snapshot hooks")
  options+=("refresh [agents] respawn agents with color env")
  options+=("sync    [pane]   refresh branch/worktree label")
  options+=("title   [pane]   set current pane title")
  options+=("colorfix [theme]  reapply tmux colors/env")
  options+=("titles  [on]     show pane title bars")
  options+=("titles  [off]    hide pane title bars")
  options+=("kill    [all]    stop tmux server")

  selection="$(choose_option "${options[@]}")"

  case "$selection" in
    attach*)
      attach_or_switch "${selection##*  }"
      ;;
    "new     [ai]     agent cockpit (3x2)")
      session="$(prompt_session_name "ai session" "studio")"
      [[ -n "$session" ]] || exit 1
      create_studio "$session"
      ;;
    "new     [cockpit] ops/L1/L2/L3 cockpit")
      session="$(prompt_session_name "cockpit session" "cockpit")"
      [[ -n "$session" ]] || exit 1
      create_ops "$session"
      ;;
    "new     [shell]  normal tmux session")
      session="$(prompt_session_name "shell session")"
      [[ -n "$session" ]] || exit 1
      create_plain "$session"
      ;;
    "new     [mobile] phone-sized tmux session")
      session="$(prompt_session_name "mobile session" "mobile")"
      [[ -n "$session" ]] || exit 1
      create_mobile "$session"
      ;;
    "reset   [ai]     kill server + fresh agent cockpit")
      session="$(prompt_session_name "fresh ai session" "studio")"
      [[ -n "$session" ]] || exit 1
      reset_to_profile ai "$session"
      ;;
    "reset   [shell]  kill server + fresh shell session")
      session="$(prompt_session_name "fresh shell session" "main")"
      [[ -n "$session" ]] || exit 1
      reset_to_profile shell "$session"
      ;;
    "reset   [mobile] kill server + fresh phone session")
      session="$(prompt_session_name "fresh mobile session" "mobile")"
      [[ -n "$session" ]] || exit 1
      reset_to_profile mobile "$session"
      ;;
    "restore [layout] unzoom windows + retile 6-pane sessions")
      restore_studio_layout
      ;;
    "restore [preview] Codex/Claude restore map")
      restore_preview
      ;;
    "recover [cockpit] rebuild CX-saved cockpit")
      recover_cockpit
      ;;
    "recover [agents] rebuild saved agent cockpit")
      recover_agent_cockpit
      ;;
    "snapshot [agents] save live agent cockpit")
      write_agent_cockpit_state
      ;;
    "snapshot [codex]  save Codex/Claude restore map")
      write_codex_cockpit_snapshot
      ;;
    "snapshot [history] list capped snapshots")
      list_snapshot_history
      ;;
    "autosave [on]    keep agent snapshot warm")
      install_agent_autosave_hooks
      write_agent_cockpit_state
      write_codex_cockpit_snapshot "$(codex_cockpit_snapshot_file)" --quiet
      ;;
    "autosave [off]   disable agent snapshot hooks")
      clear_agent_autosave_hooks
      ;;
    "refresh [agents] respawn agents with color env")
      refresh_agent_pane_colors
      ;;
    "sync    [pane]   refresh branch/worktree label")
      sync_agent_pane_context "${TMUX_PANE:-all}"
      ;;
    "title   [pane]   set current pane title")
      title="$(prompt_session_name "pane title")"
      [[ -n "$title" ]] || exit 1
      set_agent_pane_title "$title"
      ;;
    "colorfix [theme]  reapply tmux colors/env")
      apply_recovery_theme
      install_agent_autosave_hooks
      ;;
    "titles  [on]     show pane title bars")
      apply_agent_manifest_metadata "$(agent_cockpit_manifest)"
      apply_studio_pane_titles "${TMUX_PANE:-}"
      ;;
    "titles  [off]    hide pane title bars")
      clear_studio_pane_titles "${TMUX_PANE:-}"
      ;;
    "kill    [all]    stop tmux server")
      kill_server
      ;;
    *)
      echo "unknown selection: $selection" >&2
      exit 1
      ;;
  esac
}

case "${1:-}" in
  "")
    run_menu
    ;;
  ai|studio)
    create_studio "${2:-studio}"
    ;;
  ops|cockpit)
    create_ops "${2:-cockpit}"
    ;;
  upgrade-ops-shells)
    upgrade_ops_shells "${2:-cockpit}"
    ;;
  shell|plain)
    if [[ -n "${2:-}" ]]; then
      create_plain "$2"
    else
  session="$(prompt_session_name "shell session")"
      [[ -n "$session" ]] || exit 1
      create_plain "$session"
    fi
    ;;
  mobile|phone)
    if [[ -n "${2:-}" ]]; then
      create_mobile "$2"
    elif target="$(mobile_choose_pane_target)"; then
      attach_mobile_target "$target"
    else
      status=$?
      if [[ "$status" == "1" ]]; then
        create_mobile "mobile"
      fi
      exit "$status"
    fi
    ;;
  reset)
    profile="${2:-ai}"
    case "$profile" in
      ai|studio)
        reset_to_profile ai "${3:-studio}"
        ;;
      shell|plain)
        reset_to_profile shell "${3:-main}"
        ;;
      mobile|phone)
        reset_to_profile mobile "${3:-mobile}"
        ;;
      *)
        echo "usage: tt reset [ai|shell|mobile] [session]" >&2
        exit 2
        ;;
    esac
    ;;
  restore)
    restore_studio_layout "${2:-}"
    ;;
  restore-preview)
    restore_preview "${2:-}"
    ;;
  recover)
    case "${2:-cockpit}" in
      cockpit|ops|--default)
        recover_cockpit "${3:-}" "cockpit"
        ;;
      agents|agent|factory|factory2)
        recover_agent_cockpit "${3:-}" "${4:-factory2}"
        ;;
      *)
        echo "usage: tt recover [cockpit [snapshot]|agents [manifest] [attach-session]]" >&2
        exit 2
        ;;
    esac
    ;;
  snapshot|backup|save)
    if [[ "${2:-}" == "--quiet" ]]; then
      write_agent_cockpit_state "" --quiet
    else
      write_agent_cockpit_state "${2:-}" "${3:-}"
    fi
    ;;
  codex-snapshot|cx-snapshot)
    if [[ "${2:-}" == "--quiet" ]]; then
      write_codex_cockpit_snapshot "" --quiet
    else
      write_codex_cockpit_snapshot "${2:-}" "${3:-}"
    fi
    ;;
  codex-snapshot-show|cx-snapshot-show)
    show_codex_snapshot "${2:-}"
    ;;
  snapshot-history)
    list_snapshot_history "${2:-codex-cockpit}" "${3:-40}"
    ;;
  status)
    status_report
    ;;
  doctor)
    doctor_tmux "${2:---fix}"
    ;;
  popup)
    popup_view "${2:-snapshot}"
    ;;
  codex-restore|cx-restore)
    codex_restore_execute "${2:-preview}" "${3:-}" "${4:-}" "${5:-}"
    ;;
  codex-snapshot-loop)
    codex_snapshot_timer_loop
    ;;
  mosh-attn)
    sync_mosh_attention_panes "${2:-}"
    ;;
  pane-menu)
    show_pane_menu "${2:-${TMUX_PANE:-}}" "${3:-P}" "${4:-P}" "${5:-}"
    ;;
  autosave)
    case "${2:-on}" in
      on)
        install_agent_autosave_hooks
        write_agent_cockpit_state "$(agent_cockpit_state_file)" --quiet
        write_codex_cockpit_snapshot "$(codex_cockpit_snapshot_file)" --quiet
        ;;
      off)
        clear_agent_autosave_hooks
        ;;
      *)
        echo "usage: tt autosave [on|off]" >&2
        exit 2
        ;;
    esac
    ;;
  refresh)
    case "${2:-agents}" in
      agents|agent|colors|color)
        refresh_agent_pane_colors
        ;;
      *)
        echo "usage: tt refresh [agents]" >&2
        exit 2
        ;;
    esac
    ;;
  sync)
    sync_agent_pane_context "${2:-${TMUX_PANE:-all}}"
    ;;
  note)
    case "${2:-list}" in
      set)
        target="${3:-${TMUX_PANE:-}}"
        shift 3 || true
        set_pane_note "$target" "$@"
        ;;
      clear)
        clear_pane_note "${3:-${TMUX_PANE:-}}"
        ;;
      show)
        show_pane_note "${3:-${TMUX_PANE:-}}"
        ;;
      edit)
        edit_pane_note "${3:-${TMUX_PANE:-}}"
        ;;
      prompt)
        prompt_pane_note "${3:-${TMUX_PANE:-}}"
        ;;
      sync)
        sync_pane_notes "${3:-all}"
        ;;
      list)
        list_pane_notes
        ;;
      *)
        echo "usage: tt note [set <pane> <note>|clear <pane>|show <pane>|edit <pane>|prompt <pane>|sync [pane|all]|list]" >&2
        exit 2
        ;;
    esac
    ;;
  marker)
    case "${2:-list}" in
      set)
        set_pane_marker "${3:-${TMUX_PANE:-}}" "${4:-default}"
        ;;
      clear|default)
        set_pane_marker "${3:-${TMUX_PANE:-}}" default
        ;;
      sync)
        sync_pane_markers "${3:-all}"
        ;;
      list)
        list_pane_markers
        ;;
      *)
        echo "usage: tt marker [set <pane> default|amber|green|blue|dim|clear <pane>|sync [pane|all]|list]" >&2
        exit 2
        ;;
    esac
    ;;
  title)
    if [[ -n "${3:-}" ]]; then
      target="$2"
      shift 2
      set_agent_pane_title "$target" "$@"
    else
      set_agent_pane_title "${2:-}"
    fi
    ;;
  colorfix)
    apply_recovery_theme
    install_agent_autosave_hooks
    ;;
  status-audit)
    enforce_static_tmux_status
    ;;
  attention-reset)
    reset_agent_attention_pane "${2:-${TMUX_PANE:-}}"
    ;;
  titles)
    case "${2:-on}" in
      on)
        apply_agent_manifest_metadata "$(agent_cockpit_manifest)"
        apply_studio_pane_titles "${3:-}"
        ;;
      off)
        clear_studio_pane_titles "${3:-}"
        ;;
      *)
        echo "usage: tt titles [on|off] [target]" >&2
        exit 2
        ;;
    esac
    ;;
  kill)
    kill_server
    ;;
  attach)
    [[ -n "${2:-}" ]] || { echo "usage: tt attach <session>" >&2; exit 2; }
    attach_or_switch "$2"
    ;;
  ls)
    list_sessions
    ;;
  *)
    if "$TMUX_BIN" has-session -t "$1" 2>/dev/null; then
      attach_or_switch "$1"
    else
      echo "usage: tt [ai [session]|ops [session]|shell [session]|mobile [session]|reset [ai|shell|mobile] [session]|restore [target]|restore-preview [snapshot]|recover [manifest] [attach-session]|snapshot [file] [--quiet]|codex-snapshot [file] [--quiet]|codex-snapshot-show [snapshot]|snapshot-history [codex-cockpit|agent-cockpit] [limit]|status|doctor [--fix|--check]|popup [snapshot|restore-preview|snapshot-history|status|doctor]|codex-restore [preview|all|pane <target>|window <session:window>] [snapshot] [--execute]|autosave [on|off]|refresh [agents]|sync [target|all]|note [set|clear|show|edit|prompt|sync|list]|marker [set|clear|sync|list]|title [target] <short-title>|colorfix|status-audit|titles [on|off] [target]|kill|attach <session>|ls]" >&2
      exit 2
    fi
    ;;
esac
