#!/usr/bin/env bash
set -euo pipefail

usage() {
    cat <<'USAGE'
Usage:
  setup-agent-env-from-1password --openai-ref OP_REF --anthropic-ref OP_REF

Writes OPENAI_API_KEY and ANTHROPIC_API_KEY into the ignored dotfiles .env file.
Use 1Password secret references, for example:
  op://Private/OpenAI API Key/credential
  op://Private/Anthropic API Key/credential

Environment overrides:
  DOTFILES_AGENT_ENV          Destination .env file
  DOTFILES_OPENAI_API_KEY_REF OpenAI secret reference
  DOTFILES_ANTHROPIC_API_KEY_REF Anthropic secret reference
USAGE
}

quote_for_env() {
    local value="$1"
    printf "'%s'" "${value//\'/\'\\\'\'}"
}

set_or_replace_env_var() {
    local file="$1"
    local name="$2"
    local value="$3"
    local tmp

    tmp="$(mktemp "${TMPDIR:-/tmp}/agent-env.XXXXXX")"
    if [[ -f "$file" ]]; then
        grep -v -E "^${name}=" "$file" > "$tmp" || true
    fi
    printf "%s=%s\n" "$name" "$(quote_for_env "$value")" >> "$tmp"
    chmod 600 "$tmp"
    mv "$tmp" "$file"
}

openai_ref="${DOTFILES_OPENAI_API_KEY_REF:-}"
anthropic_ref="${DOTFILES_ANTHROPIC_API_KEY_REF:-}"

while (($#)); do
    case "$1" in
        --openai-ref)
            openai_ref="${2:-}"
            shift 2
            ;;
        --anthropic-ref)
            anthropic_ref="${2:-}"
            shift 2
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown argument: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

if [[ -z "$openai_ref" || -z "$anthropic_ref" ]]; then
    echo "Missing required 1Password secret refs." >&2
    usage >&2
    exit 2
fi

if ! command -v op >/dev/null 2>&1; then
    echo "1Password CLI not found: op" >&2
    exit 1
fi

if ! op whoami >/dev/null 2>&1; then
    echo "1Password CLI is not signed in or app integration is unavailable." >&2
    exit 1
fi

openai_key="$(op read "$openai_ref")"
anthropic_key="$(op read "$anthropic_ref")"

if [[ -z "$openai_key" || -z "$anthropic_key" ]]; then
    echo "One or more 1Password refs returned an empty value." >&2
    exit 1
fi

if [[ "$OSTYPE" == darwin* ]]; then
    env_file="${DOTFILES_AGENT_ENV:-$HOME/Library/Mobile Documents/com~apple~CloudDocs/dotfiles/.env}"
else
    env_file="${DOTFILES_AGENT_ENV:-$HOME/.dotfiles/.env}"
fi

mkdir -p "$(dirname "$env_file")"
touch "$env_file"
chmod 600 "$env_file"

set_or_replace_env_var "$env_file" "OPENAI_API_KEY" "$openai_key"
set_or_replace_env_var "$env_file" "ANTHROPIC_API_KEY" "$anthropic_key"

echo "Wrote agent API key environment to: $env_file"
echo "Updated keys: OPENAI_API_KEY ANTHROPIC_API_KEY"
