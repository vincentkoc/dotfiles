#!/usr/bin/env bash
set -euo pipefail

if [[ -z "${TMUX_PANE:-}" ]]; then
  echo "TMUX_PANE not set" >&2
  exit 1
fi

if command -v tt >/dev/null 2>&1; then
  exec tt sync "$TMUX_PANE"
fi

git_label=""
if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  branch="$(git symbolic-ref --short HEAD 2>/dev/null || git rev-parse --short HEAD 2>/dev/null || true)"
  [[ -n "$branch" ]] && git_label=" $branch"
fi

if [[ -n "$git_label" ]]; then
  tmux set-option -pt "$TMUX_PANE" @tt_git_label "$git_label"
else
  tmux set-option -pt "$TMUX_PANE" -u @tt_git_label >/dev/null 2>&1 || true
fi
